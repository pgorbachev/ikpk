{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "typecheck": "astro check",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "test": "vitest run --exclude tests/site.spec.ts --exclude tests/compare.spec.ts --exclude tests/compat.spec.ts --exclude tests/perf-a11y.test.ts",
    "test:build": "astro build && vitest run tests/perf-a11y.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:compat": "playwright test tests/compat.spec.ts --project=compat-chrome-desktop --project=compat-firefox-desktop --project=compat-safari-desktop --project=compat-ios-iphone-se --project=compat-ios-iphone-14 --project=compat-ios-ipad --project=compat-android-chrome"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.37.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.2"
  }
}
