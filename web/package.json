{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "typecheck": "astro check",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "test": "vitest run",
    "test:build": "npm run build && vitest run --config vitest.build.config.ts",
    "test:build:remote": "npm run build && PARITY_REMOTE=1 PARITY_REMOTE_STRICT=1 vitest run --config vitest.build.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/site.spec.ts --project=desktop --project=mobile",
    "test:e2e:a11y": "playwright test tests/a11y.spec.ts --project=desktop --project=mobile",
    "test:e2e:compat": "playwright test tests/compat.spec.ts --project=compat-chrome-desktop --project=compat-firefox-desktop --project=compat-safari-desktop --project=compat-ios-iphone-se --project=compat-ios-iphone-14 --project=compat-ios-ipad --project=compat-android-chrome",
    "test:e2e:smoke:attached": "playwright test tests/site.spec.ts --config=playwright.attached.config.ts --project=desktop --project=mobile",
    "test:e2e:compat:attached": "playwright test tests/compat.spec.ts --config=playwright.attached.config.ts --project=compat-chrome-desktop --project=compat-firefox-desktop --project=compat-safari-desktop --project=compat-ios-iphone-se --project=compat-ios-iphone-14 --project=compat-ios-ipad --project=compat-android-chrome",
    "test:compare:attached": "playwright test tests/compare.spec.ts --config=playwright.attached.config.ts --project=desktop",
    "verify": "npm test && npm run test:build && npm run test:e2e:smoke && npm run test:e2e:compat",
    "verify:attached": "npm test && npm run test:build && npm run test:e2e:smoke:attached && npm run test:e2e:compat:attached"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.37.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.37.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.4.0",
    "pagefind": "^1.5.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.2"
  }
}
