---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactShell from '../components/contacts/ContactShell.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { getPage } from '../lib/data';

const page = getPage('kontakty');
const title = page?.seo_title || 'Контакты — ИКПК';
const description = page?.seo_description || 'Контактная информация ИКПК.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78126465450',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Новочеркасский пр-т, д. 22/15, Лит А, помещение 4Н',
    addressLocality: 'Санкт-Петербург',
    postalCode: '195112',
    addressCountry: 'RU',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+78126465450',
    email: 'info@ikpk.su',
    contactType: 'customer service',
    availableLanguage: 'Russian',
  },
};

const mapSrc = `https://yandex.ru/map-widget/v1/?text=${encodeURIComponent('Санкт-Петербург, Новочеркасский пр-т, д. 22/15, Лит А, помещение 4Н')}&z=16`;
---

<BaseLayout title={title} description={description} schema={schema} newsletterVariant="card">
  <div class="container">
    <Breadcrumbs items={[{ label: 'Контакты' }]} />

    <section class="section">
      <PageHeader title="Контакты" compact={true} />

      <ContactShell
        address="Новочеркасский пр-т, д. 22/15, Лит А, помещение 4Н"
        addressLabel="Санкт-Петербург"
        hoursWeekdays="10:00 - 18:00"
        hoursWeekend="выходной"
        institutePhone="+7 (812) 646-54-50"
        email="info@ikpk.su"
        storeUrl="https://medshop.ikpk.su"
        clinicPhone="+7 (812) 646-54-60"
        clinicUrl="https://mudriydoctor.ru"
        requisites={[
          'ООО «Институт клинической прикладной кинезиологии»',
          'ИНН/КПП 7811351115 / 780601001, ОГРН 5067847182651.',
          'Юридический адрес: 195112, Санкт-Петербург, Новочеркасский пр-т, д. 22/15, Лит А, помещение 4Н.',
          'Телефон: +7 (812) 646-54-50',
        ]}
        mapSrc={mapSrc}
        mapOpenUrl="https://yandex.ru/maps/?text=Санкт-Петербург,+Новочеркасский+пр-т,+д.+22/15"
      />
    </section>
  </div>
</BaseLayout>

<style>
  .section :global(.page-header) {
    margin-bottom: 1.35rem;
  }
</style>
