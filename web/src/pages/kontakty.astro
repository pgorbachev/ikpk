---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getPage, stripH1 } from '../lib/data';

const page = getPage('kontakty');
const title = page?.seo_title || 'Контакты — ИКПК';
const description = page?.seo_description || 'Контактная информация ИКПК.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78126465450',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Санкт-Петербург',
    addressCountry: 'RU',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+78126465450',
    email: 'info@ikpk.su',
    contactType: 'customer service',
    availableLanguage: 'Russian',
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Контакты' }]} />

    <section class="section">
      <h1 class="page-title">Контакты</h1>

      <div class="contacts-grid">
        <div class="contact-block">
          <h2>Телефон</h2>
          <a href="tel:+78126465450" class="contact-value">+7 (812) 646-54-50</a>
        </div>
        <div class="contact-block">
          <h2>Email</h2>
          <a href="mailto:info@ikpk.su" class="contact-value">info@ikpk.su</a>
        </div>
        <div class="contact-block">
          <h2>Адрес</h2>
          <p class="contact-value">Санкт-Петербург</p>
        </div>
      </div>

      {page?.body_html ? (
        <div class="contacts-extra rich-content" set:html={stripH1(page.body_html)} />
      ) : page?.body_text && (
        <div class="contacts-extra rich-content">
          <p>{page.body_text}</p>
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 2rem;
  }

  .contacts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .contact-block h2 {
    font-size: var(--font-s);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500);
    margin-bottom: 0.5rem;
  }

  .contact-value {
    font-size: var(--font-xl);
    font-weight: 600;
    color: var(--color-dark-700);
  }

  a.contact-value {
    color: var(--color-accent-500);
  }

  .contacts-extra {
    max-width: 800px;
  }

  @media (max-width: 768px) {
    .contacts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
