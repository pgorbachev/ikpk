---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import {
  getInstitutes,
  getCourseGroups,
  getSeminars,
  getScheduleEntries,
  formatPrice,
  formatDate,
} from '../../../lib/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const institutes = getInstitutes();
  const allCGs = getCourseGroups();
  const allSeminars = getSeminars();
  const paths: { params: Record<string, string>; props: Record<string, unknown> }[] = [];

  for (const sem of allSeminars) {
    const cg = allCGs.find((c) => c.legacy_id === sem.course_group_legacy_id);
    if (!cg) continue;
    const inst = institutes.find((i) => i.slug === cg.institute_legacy_id);
    if (!inst) continue;
    paths.push({
      params: { institute: inst.slug, courseGroup: cg.slug, seminar: sem.slug },
      props: { seminar: sem, courseGroup: cg, institute: inst },
    });
  }
  return paths;
};

const { seminar, courseGroup, institute } = Astro.props;

const schedule = getScheduleEntries().filter(
  (e) => e.seminar?.slug === seminar.slug && e.status === 'active'
);

const statusLabel: Record<string, string> = {
  active: 'Набор открыт',
  not_planned: 'Не запланирован',
  completed: 'Завершён',
};
---

<BaseLayout title={seminar.seo_title} description={seminar.seo_description}>
  <div class="container">
    <Breadcrumbs
      items={[
        { label: institute.name, href: `/${institute.slug}` },
        { label: courseGroup.name, href: `/${institute.slug}/${courseGroup.slug}` },
        { label: seminar.name },
      ]}
    />

    <article class="section seminar-detail">
      <h1 class="page-title">{seminar.name}</h1>

      <div class="seminar-meta">
        {seminar.status && (
          <span class:list={['badge', `badge-${seminar.status}`]}>
            {statusLabel[seminar.status] || seminar.status}
          </span>
        )}
      </div>

      {seminar.description_text && (
        <div class="seminar-content rich-content">
          <p>{seminar.description_text}</p>
        </div>
      )}

      {schedule.length > 0 && (
        <section class="schedule-section">
          <h2 class="section-title">Расписание</h2>
          <div class="schedule-list">
            {schedule.map((entry) => (
              <div class="schedule-entry card">
                <div class="card-body">
                  <div class="schedule-row">
                    <div>
                      <strong>{formatDate(entry.startAt)}</strong>
                      {entry.startAt !== entry.endAt && (
                        <span> — {formatDate(entry.endAt)}</span>
                      )}
                    </div>
                    <div class="schedule-city">{entry.city?.name}</div>
                    <div class="schedule-price">
                      {entry.isFree ? 'Бесплатно' : formatPrice(entry.newPrice)}
                    </div>
                  </div>
                  {entry.teachers?.length > 0 && (
                    <div class="schedule-teachers text-small text-muted">
                      {entry.teachers.map((t) => t.fullName).join(', ')}
                    </div>
                  )}
                  {entry.duration && (
                    <div class="text-small text-muted">Длительность: {entry.duration} ч.</div>
                  )}
                  {entry.registrationFormLink && (
                    <a href={entry.registrationFormLink} class="btn btn-primary schedule-btn" target="_blank" rel="noopener">
                      Записаться
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {schedule.length === 0 && (
        <div class="no-schedule">
          <p class="text-muted">В настоящий момент данный курс ещё не запланирован.</p>
          <a href="/raspisanie-i-tseny" class="btn btn-outline">Смотреть всё расписание</a>
        </div>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 0.75rem;
  }

  .seminar-meta {
    margin-bottom: 1.5rem;
  }

  .seminar-content {
    max-width: 800px;
    margin-bottom: 2rem;
  }

  .badge-active {
    background-color: var(--color-accent-50);
    color: var(--color-accent-700);
  }

  .badge-not_planned {
    background-color: #fef3cd;
    color: #856404;
  }

  .badge-completed {
    background-color: var(--color-gray-200);
    color: var(--color-gray-600);
  }

  .schedule-section {
    margin-top: 2rem;
  }

  .schedule-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .schedule-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .schedule-city {
    color: var(--color-gray-600);
  }

  .schedule-price {
    font-weight: 600;
    color: var(--color-dark-700);
  }

  .schedule-btn {
    margin-top: 0.75rem;
    font-size: var(--font-s);
  }

  .no-schedule {
    margin-top: 2rem;
    padding: 2rem;
    background: var(--color-light-300);
    border-radius: var(--radius-m);
    text-align: center;
  }

  .no-schedule .btn {
    margin-top: 1rem;
  }
</style>
