---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SeminarScheduleSection from '../../../components/seminars/SeminarScheduleSection.astro';
import {
  getInstitutes,
  getCourseGroups,
  getSeminars,
  getScheduleEntries,
  getTeachers,
  cleanBodyHtml,
  stripLegacySeminarTail,
} from '../../../lib/data';
import type { CourseGroup, Institute, Seminar } from '../../../lib/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const institutes = getInstitutes();
  const allCGs = getCourseGroups();
  const allSeminars = getSeminars();
  const paths: { params: Record<string, string>; props: Record<string, unknown> }[] = [];

  for (const sem of allSeminars) {
    const cg = allCGs.find((c) => c.legacy_id === sem.course_group_legacy_id);
    if (!cg) continue;
    const inst = institutes.find((i) => i.slug === cg.institute_legacy_id);
    if (!inst) continue;
    paths.push({
      params: { institute: inst.slug, courseGroup: cg.slug, seminar: sem.slug },
      props: { seminar: sem, courseGroup: cg, institute: inst },
    });
  }
  return paths;
};

const { seminar, courseGroup, institute } = Astro.props as {
  seminar: Seminar;
  courseGroup: CourseGroup;
  institute: Institute;
};

const today = new Date();
today.setHours(0, 0, 0, 0);
const schedule = getScheduleEntries().filter(
  (e) =>
    e.seminar?.slug === seminar.slug &&
    e.status === 'active' &&
    new Date(e.startAt).getTime() >= today.getTime()
);
const sortedSchedule = [...schedule].sort(
  (a, b) => new Date(a.startAt).getTime() - new Date(b.startAt).getTime()
);
const allTeachers = getTeachers();
const seminarUrl = `https://ikpk.su/${institute.slug}/${courseGroup.slug}/${seminar.slug}`;
const scheduleRows = sortedSchedule.map((entry) => ({
  entry,
  teachers: (entry.teachers || []).map((teacher) => {
    const full = allTeachers.find(
      (candidate) =>
        candidate.slug === String(teacher.id) ||
        candidate.legacy_id === String(teacher.id) ||
        candidate.name === teacher.fullName
    );

    return {
      fullName: teacher.fullName,
      href: `/${full?.institute_legacy_id || institute.slug}/prepodavatel/${full?.slug || teacher.id}`,
    };
  }),
}));
const seminarBodyHtml = seminar.description_html
  ? cleanBodyHtml(stripLegacySeminarTail(seminar.description_html))
  : '';

// Event без startDate невалиден (Google Rich Results) — Этап 3, план 004.
// Семинар с назначенной датой → Event; без даты → Course (программа обучения).
const seminarSchema =
  schedule.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'Event',
        name: seminar.name,
        description: seminar.seo_description || seminar.description_text?.slice(0, 200),
        url: seminarUrl,
        organizer: {
          '@type': 'EducationalOrganization',
          name: 'ИКПК',
          url: 'https://ikpk.su',
        },
        location: {
          '@type': 'Place',
          name: 'ИКПК',
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Санкт-Петербург',
            addressCountry: 'RU',
          },
        },
        startDate: schedule[0].startAt,
        endDate: schedule[0].endAt,
        eventStatus: 'https://schema.org/EventScheduled',
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        offers: {
          '@type': 'Offer',
          url: seminarUrl,
          price: schedule[0].isFree ? '0' : String(schedule[0].newPrice),
          priceCurrency: 'RUB',
          availability: 'https://schema.org/InStock',
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Course',
        name: seminar.name,
        description: seminar.seo_description || seminar.description_text?.slice(0, 200),
        url: seminarUrl,
        provider: {
          '@type': 'EducationalOrganization',
          name: 'ИКПК',
          url: 'https://ikpk.su',
        },
      };
---

<BaseLayout title={seminar.seo_title} description={seminar.seo_description} schema={seminarSchema}>
  <div class="container">
    <Breadcrumbs
      items={[
        { label: institute.name, href: `/${institute.slug}` },
        { label: courseGroup.name, href: `/${institute.slug}/${courseGroup.slug}` },
        { label: seminar.name },
      ]}
    />

    <article class="section seminar-detail">
      <h1 class="page-title">{seminar.name}</h1>

      {seminarBodyHtml ? (
        <div class="seminar-content rich-content" set:html={seminarBodyHtml} />
      ) : seminar.description_text && (
        <div class="seminar-content rich-content">
          <p>{seminar.description_text}</p>
        </div>
      )}

      <SeminarScheduleSection rows={scheduleRows} />
    </article>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin: 0 0 1.75rem;
    font-size: clamp(2rem, 1.65rem + 1.2vw, 3rem);
    line-height: 1.12;
  }

  .seminar-content {
    margin-bottom: 0;
    line-height: 1.75;
  }
</style>
