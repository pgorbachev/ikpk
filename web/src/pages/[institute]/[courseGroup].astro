---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SeminarCard from '../../components/SeminarCard.astro';
import { getInstitutes, getCourseGroups, getSeminars, excerpt } from '../../lib/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const institutes = getInstitutes();
  const allCGs = getCourseGroups();
  const paths: { params: Record<string, string>; props: Record<string, unknown> }[] = [];

  for (const cg of allCGs) {
    const inst = institutes.find((i) => i.slug === cg.institute_legacy_id);
    if (!inst) continue;
    paths.push({
      params: { institute: inst.slug, courseGroup: cg.slug },
      props: { courseGroup: cg, institute: inst },
    });
  }
  return paths;
};

const { courseGroup, institute } = Astro.props;
const seminars = getSeminars(courseGroup.legacy_id);
---

<BaseLayout title={courseGroup.seo_title} description={courseGroup.seo_description}>
  <div class="container">
    <Breadcrumbs
      items={[
        { label: institute.name, href: `/${institute.slug}` },
        { label: courseGroup.name },
      ]}
    />

    <section class="section">
      <h1 class="page-title">{courseGroup.name}</h1>

      {courseGroup.description_text && (
        <div class="cg-intro">
          <p>{excerpt(courseGroup.description_text, 500)}</p>
        </div>
      )}
    </section>

    {seminars.length > 0 && (
      <section class="section">
        <h2 class="section-title">Семинары и курсы</h2>
        <div class="grid grid-2">
          {seminars.map((s) => (
            <SeminarCard
              seminar={s}
              href={`/${institute.slug}/${courseGroup.slug}/${s.slug}`}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1rem;
  }

  .cg-intro {
    max-width: 800px;
    font-size: var(--font-l);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
</style>
