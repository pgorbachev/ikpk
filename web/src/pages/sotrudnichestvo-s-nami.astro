---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getPage, cleanBodyHtml } from '../lib/data';

const page = getPage('sotrudnichestvo-s-nami');
const title = page?.seo_title || 'Сотрудничество — ИКПК';
const description = page?.seo_description || 'Информация о сотрудничестве с ИКПК.';
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Сотрудничество' }]} />

    <section class="section">
      <h1 class="page-title">Сотрудничество с нами</h1>

      {page?.body_html ? (
        <div class="collab-content rich-content" set:html={cleanBodyHtml(page.body_html)} />
      ) : (
        <p class="text-muted">Информация о сотрудничестве будет добавлена позже.</p>
      )}

      <section class="cta-section" aria-label="Контакты для сотрудничества">
        <h2 class="cta-title">Свяжитесь с нами</h2>
        <p class="cta-text">
          Мы открыты для сотрудничества и рады обсудить любые предложения.
        </p>
        <div class="cta-contacts">
          <a href="tel:+78126465450" class="cta-contact-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>+7 (812) 646-54-50</span>
          </a>
          <a href="mailto:info@ikpk.su" class="cta-contact-item">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span>info@ikpk.su</span>
          </a>
        </div>
        <a href="/kontakty" class="btn btn-primary cta-btn">Перейти к контактам</a>
      </section>
    </section>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1.5rem;
  }

  .collab-content {
    max-width: 800px;
    margin-bottom: 3rem;
  }

  /* CTA Section */
  .cta-section {
    max-width: 700px;
    background: linear-gradient(135deg, var(--color-accent-50) 0%, var(--color-light-300) 100%);
    border: 1px solid var(--color-accent-200);
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
  }

  .cta-title {
    font-size: var(--font-xxl);
    color: var(--color-dark-700);
    margin-bottom: 0.5rem;
  }

  .cta-text {
    color: var(--color-gray-600);
    margin-bottom: 1.5rem;
    font-size: var(--font-l);
  }

  .cta-contacts {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .cta-contact-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent-600);
    font-weight: 600;
    font-size: var(--font-l);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cta-contact-item:hover {
    color: var(--color-accent-700);
    text-decoration: none;
  }

  .cta-contact-item svg {
    flex-shrink: 0;
  }

  .cta-btn {
    padding: 0.75rem 2.5rem;
    font-size: var(--font-l);
  }

  @media (max-width: 640px) {
    .cta-section {
      padding: 1.75rem 1.25rem;
    }

    .cta-contacts {
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }
  }
</style>
