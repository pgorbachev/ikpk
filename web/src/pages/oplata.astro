---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getPage } from '../lib/data';

const page = getPage('oplata');
const title = page?.seo_title || 'Оплата — ИКПК';
const description = page?.seo_description || 'Информация об оплате обучения в ИКПК.';
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Оплата' }]} />

    <section class="section">
      <h1 class="page-title">Оплата</h1>

      {page?.body_text ? (
        <div class="page-content rich-content">
          <p>{page.body_text}</p>
        </div>
      ) : (
        <p class="text-muted">Информация об оплате будет добавлена позже.</p>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .page-title { margin-bottom: 1.5rem; }
  .page-content { max-width: 800px; }
</style>
