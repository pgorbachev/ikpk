---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getVideoPlaylists, getPage } from '../../lib/data';
import { VK_CHANNEL_URL, RUTUBE_CHANNEL_URL, getVideoMirror } from '../../lib/video-mirrors';

const page = getPage('video');
const playlists = getVideoPlaylists().map((pl) => ({ ...pl, mirror: getVideoMirror(pl.slug) }));

const title = page?.seo_title || 'Видео — ИКПК';
const description = page?.seo_description || 'Видеоматериалы ИКПК.';
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Видео' }]} />

    <section class="section">
      <h1 class="page-title">Видео</h1>

      <div class="video-notice">
        <p>
          В связи с тем, что видеохостинг YouTube в РФ работает нестабильно,
          мы дублируем все видео на платформы
          <a href={VK_CHANNEL_URL} target="_blank" rel="noopener noreferrer">VK Видео</a> и
          <a href={RUTUBE_CHANNEL_URL} target="_blank" rel="noopener noreferrer">RUTUBE</a>.
        </p>
      </div>

      {playlists.length > 0 ? (
        <div class="grid grid-3">
          {playlists.map((pl) => (
            <a href={`/video/${pl.slug}`} class="card playlist-card">
              <div class="playlist-thumb">
                {pl.mirror?.thumbnail && (
                  <img src={pl.mirror.thumbnail} alt={`Плейлист «${pl.title}»`} width="640" height="360" loading="lazy" />
                )}
                <span class="playlist-play" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="26" height="26"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
                </span>
                {pl.mirror && (
                  <span class="playlist-count">
                    {pl.mirror.videoCount}{pl.mirror.videoCountCapped ? '+' : ''} видео
                  </span>
                )}
              </div>
              <div class="card-body">
                <h3 class="playlist-title">{pl.title}</h3>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-muted">Видео пока не добавлены.</p>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1rem;
  }

  .video-notice {
    background: #e8f4fd;
    border-left: 4px solid var(--color-info-500);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-m);
    margin-bottom: 2rem;
    font-size: var(--font-s);
  }

  .playlist-card {
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .playlist-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgb(0 0 0 / 10%);
  }

  .playlist-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #1e3b1f, #0d1a0d);
    overflow: hidden;
  }
  .playlist-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .playlist-play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgb(0 0 0 / 55%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 3px;
    transition: background 0.2s, transform 0.2s;
  }
  .playlist-card:hover .playlist-play {
    background: var(--color-accent-500);
    transform: scale(1.06);
  }
  .playlist-count {
    position: absolute;
    right: 8px;
    bottom: 8px;
    background: var(--color-accent-500);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
  }

  .playlist-title {
    font-size: var(--font-m);
    font-weight: 600;
    color: var(--color-dark-700);
    padding: 0.9rem 1rem;
  }
</style>
