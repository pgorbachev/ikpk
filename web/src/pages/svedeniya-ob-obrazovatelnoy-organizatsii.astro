---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getPage, cleanBodyHtml } from '../lib/data';

const page = getPage('svedeniya-ob-obrazovatelnoy-organizatsii');
const title = page?.seo_title || 'Сведения об образовательной организации — ИКПК';
const description = page?.seo_description || 'Сведения об образовательной организации ИКПК.';
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Сведения об организации' }]} />

    <section class="section">
      <h1 class="page-title">Сведения об образовательной организации</h1>

      <p class="page-intro">
        В соответствии с требованиями законодательства об образовании, ниже представлена информация
        об&nbsp;ООО&nbsp;«Институт клинической прикладной кинезиологии».
      </p>

      {page?.body_html ? (
        <div class="svedeniya-content rich-content" set:html={cleanBodyHtml(page.body_html)} />
      ) : (
        <p class="text-muted">Информация будет добавлена позже.</p>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1rem;
  }

  .page-intro {
    color: var(--color-gray-600);
    margin-bottom: 2rem;
    max-width: 800px;
    line-height: 1.7;
  }

  .svedeniya-content {
    max-width: 860px;
  }

  /* Accordion-style details for this page */
  .svedeniya-content :global(details) {
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
    padding: 0;
    margin-bottom: 0.75rem;
    background: var(--color-light-100);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .svedeniya-content :global(details:hover) {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .svedeniya-content :global(details summary) {
    padding: 1rem 1.25rem;
    font-size: var(--font-l);
    font-weight: 600;
    color: var(--color-dark-700);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    user-select: none;
    transition: background-color 0.15s;
  }

  .svedeniya-content :global(details summary:hover) {
    background-color: var(--color-light-300);
  }

  .svedeniya-content :global(details summary::-webkit-details-marker) {
    display: none;
  }

  .svedeniya-content :global(details summary::after) {
    content: '';
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid var(--color-gray-500);
    border-bottom: 2px solid var(--color-gray-500);
    transform: rotate(-45deg);
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }

  .svedeniya-content :global(details[open] summary::after) {
    transform: rotate(45deg);
  }

  .svedeniya-content :global(details[open] summary) {
    margin-bottom: 0;
    border-bottom: 1px solid var(--color-gray-200);
    background-color: var(--color-light-300);
  }

  .svedeniya-content :global(details > :not(summary)) {
    padding: 0 1.25rem;
  }

  .svedeniya-content :global(details > :nth-child(2)) {
    padding-top: 1rem;
  }

  .svedeniya-content :global(details > :last-child) {
    padding-bottom: 1rem;
  }

  /* Number the sections */
  .svedeniya-content {
    counter-reset: section-counter;
  }

  .svedeniya-content :global(details) {
    counter-increment: section-counter;
  }

  .svedeniya-content :global(details summary::before) {
    content: counter(section-counter) '.';
    color: var(--color-accent-500);
    font-weight: 700;
    margin-right: 0.5rem;
    min-width: 1.5rem;
  }
</style>
