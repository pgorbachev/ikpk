---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getArticles, formatDate, stripH1 } from '../../lib/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const articles = getArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
};

const { article } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.seo_title || article.title,
  description: article.seo_description || article.body_text?.slice(0, 200),
  url: `https://ikpk.su/statyi/${article.slug}`,
  ...(article.published_at ? { datePublished: article.published_at } : {}),
  ...(article.image ? { image: article.image } : {}),
  author: {
    '@type': 'Organization',
    name: 'ИКПК',
    url: 'https://ikpk.su',
  },
  publisher: {
    '@type': 'Organization',
    name: 'ИКПК',
    url: 'https://ikpk.su',
  },
};
---

<BaseLayout title={article.seo_title} description={article.seo_description} schema={articleSchema}>
  <div class="container">
    <Breadcrumbs
      items={[
        { label: 'Статьи', href: '/statyi' },
        { label: article.title },
      ]}
    />

    <article class="section article-detail">
      <header class="article-header">
        <h1 class="page-title">{article.title}</h1>
        {article.published_at && (
          <time class="article-date text-muted text-small" datetime={article.published_at}>
            {formatDate(article.published_at)}
          </time>
        )}
      </header>

      {article.image && (
        <div class="article-hero-image">
          <img src={article.image} alt={article.title} loading="lazy" width="800" height="450" />
        </div>
      )}

      <div class="article-body rich-content" set:html={stripH1(article.body_html)} />

      <footer class="article-footer">
        <a href="/statyi" class="btn btn-outline">← Все статьи</a>
      </footer>
    </article>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 0.5rem;
  }

  .article-header {
    margin-bottom: 1.5rem;
  }

  .article-hero-image {
    margin-bottom: 2rem;
    border-radius: var(--radius-m);
    overflow: hidden;
    max-width: 800px;
  }

  .article-hero-image img {
    width: 100%;
    height: auto;
  }

  .article-body {
    max-width: 800px;
    line-height: 1.8;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-gray-200);
  }
</style>
