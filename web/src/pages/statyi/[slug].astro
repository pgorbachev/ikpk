---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import AsideCard from '../../components/ui/AsideCard.astro';
import MetaLabel from '../../components/ui/MetaLabel.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { getArticles, formatDate, cleanBodyHtml } from '../../lib/data';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const articles = getArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
};

const { article } = Astro.props;

// Pick up to 4 other articles for "related" section
const allArticles = getArticles().filter((a) => a.slug !== article.slug);
const shuffled = allArticles.sort(() => Math.random() - 0.5);
const relatedArticles = shuffled.slice(0, 4);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.seo_title || article.title,
  description: article.seo_description || article.body_text?.slice(0, 200),
  url: `https://ikpk.su/statyi/${article.slug}`,
  ...(article.published_at ? { datePublished: article.published_at } : {}),
  ...(article.image ? { image: article.image } : {}),
  author: {
    '@type': 'Organization',
    name: 'ИКПК',
    url: 'https://ikpk.su',
  },
  publisher: {
    '@type': 'Organization',
    name: 'ИКПК',
    url: 'https://ikpk.su',
  },
};
---

<BaseLayout title={article.seo_title} description={article.seo_description} schema={articleSchema}>
  <div class="container">
    <Breadcrumbs
      items={[
        { label: 'Статьи', href: '/statyi' },
        { label: article.title },
      ]}
    />

    {/* Hero image — full width above the 2-column layout */}
    {article.image && (
      <div class="article-hero">
        <img src={article.image} alt={article.title} loading="eager" width="1200" height="500" />
      </div>
    )}

    <div class="content-sidebar-layout article-layout" style="--layout-aside-width: 280px;">
      {/* Main content column */}
      <article class="content-sidebar-main article-main">
        <PageHeader title={article.title} compact={true} className="article-header">
          {article.published_at && (
            <time class="article-date page-header-meta text-muted" datetime={article.published_at}>
              {formatDate(article.published_at)}
            </time>
          )}
        </PageHeader>

        <div class="article-body rich-content" set:html={cleanBodyHtml(article.body_html)} />
      </article>

      {/* Sidebar column */}
      <aside class="content-sidebar-aside content-sidebar-aside--sticky article-sidebar">
        <AsideCard tone="muted">
          {article.published_at && (
            <div class="sidebar-meta">
              <MetaLabel>Дата публикации</MetaLabel>
              <time datetime={article.published_at}>{formatDate(article.published_at)}</time>
            </div>
          )}
          <a href="/statyi" class="btn btn-outline sidebar-back-link">← Все статьи</a>
        </AsideCard>

        {relatedArticles.length > 0 && (
          <AsideCard tone="muted" title="Другие статьи">
            <ul class="sidebar-articles">
              {relatedArticles.slice(0, 4).map((rel) => (
                <li>
                  <a href={`/statyi/${rel.slug}`} class="sidebar-article-link">
                    <span class="sidebar-article-title">{rel.title}</span>
                    {rel.published_at && (
                      <time class="sidebar-article-date text-muted" datetime={rel.published_at}>
                        {formatDate(rel.published_at)}
                      </time>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </AsideCard>
        )}
      </aside>
    </div>

    {/* Full-width related articles cards */}
    {relatedArticles.length > 0 && (
      <section class="related-section section">
        <h2 class="section-title">Другие статьи</h2>
        <div class="grid grid-4">
          {relatedArticles.map((rel) => (
            <ArticleCard article={rel} />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  /* Hero image — full bleed within container */
  .article-hero {
    margin-bottom: 2rem;
    border-radius: var(--radius-m);
    overflow: hidden;
    aspect-ratio: 21 / 9;
    background: var(--color-light-300);
  }

  .article-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-header {
    margin-bottom: 0;
  }

  .article-body {
    line-height: 1.8;
  }

  .sidebar-meta {
    margin-bottom: 1rem;
  }

  .sidebar-meta time {
    font-size: var(--font-s);
    color: var(--color-dark-700);
    font-weight: 500;
  }

  .sidebar-back-link {
    display: block;
    text-align: center;
    width: 100%;
  }

  .sidebar-articles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-articles li {
    border-bottom: 1px solid var(--color-gray-200);
    padding-bottom: 0.75rem;
  }

  .sidebar-articles li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sidebar-article-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .sidebar-article-link:hover .sidebar-article-title {
    color: var(--color-accent-500);
  }

  .sidebar-article-title {
    display: block;
    font-size: var(--font-s);
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-dark-700);
    transition: color 0.15s;
  }

  .sidebar-article-date {
    display: block;
    font-size: var(--font-xs);
    margin-top: 0.125rem;
  }

  /* Full-width related articles section */
  .related-section {
    border-top: 1px solid var(--color-gray-200);
    margin-top: 3rem;
  }
</style>
