---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getScheduleEntries, formatPrice, formatDate, getPage } from '../lib/data';

const page = getPage('raspisanie-i-tseny');
const entries = getScheduleEntries()
  .filter((e) => e.status === 'active')
  .sort((a, b) => new Date(a.startAt).getTime() - new Date(b.startAt).getTime());

const title = page?.seo_title || 'Расписание и цены — ИКПК';
const description = page?.seo_description || 'Расписание семинаров и цены на обучение в ИКПК.';
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Расписание и цены' }]} />

    <section class="section">
      <h1 class="page-title">Расписание и цены</h1>

      {entries.length > 0 ? (
        <div class="schedule-table-wrap">
          <table class="schedule-table">
            <thead>
              <tr>
                <th>Дата</th>
                <th>Семинар</th>
                <th>Институт</th>
                <th>Город</th>
                <th>Преподаватель</th>
                <th>Цена</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {entries.map((entry) => (
                <tr>
                  <td class="schedule-date">
                    <span>{formatDate(entry.startAt)}</span>
                    {entry.startAt !== entry.endAt && (
                      <span class="text-muted"> — {formatDate(entry.endAt)}</span>
                    )}
                  </td>
                  <td>
                    <strong>{entry.name}</strong>
                    {entry.additionalText && (
                      <span class="badge">{entry.additionalText}</span>
                    )}
                    {entry.duration && (
                      <span class="text-small text-muted"> ({entry.duration} ч.)</span>
                    )}
                  </td>
                  <td class="text-small">{entry.institute?.shortname || entry.institute?.name}</td>
                  <td>{entry.city?.name}</td>
                  <td class="text-small">
                    {entry.teachers?.map((t) => t.fullName).join(', ')}
                  </td>
                  <td class="schedule-price">
                    {entry.isFree ? 'Бесплатно' : formatPrice(entry.newPrice)}
                  </td>
                  <td>
                    {entry.registrationFormLink && (
                      <a href={entry.registrationFormLink} class="btn btn-primary btn-sm" target="_blank" rel="noopener">
                        Записаться
                      </a>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="text-muted">В данный момент расписание не заполнено.</p>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1.5rem;
  }

  .schedule-table-wrap {
    overflow-x: auto;
  }

  .schedule-table {
    width: 100%;
    border: 1px solid var(--color-gray-200);
  }

  .schedule-table th {
    background: var(--color-light-300);
    padding: 0.75rem;
    text-align: left;
    font-size: var(--font-s);
    font-weight: 600;
    color: var(--color-dark-700);
    border-bottom: 2px solid var(--color-gray-200);
    white-space: nowrap;
  }

  .schedule-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-gray-200);
    vertical-align: top;
    font-size: var(--font-s);
  }

  .schedule-table tr:hover {
    background: var(--color-accent-50);
  }

  .schedule-date {
    white-space: nowrap;
  }

  .schedule-price {
    font-weight: 600;
    white-space: nowrap;
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: var(--font-xs);
  }

  .badge {
    margin-left: 0.5rem;
  }
</style>
