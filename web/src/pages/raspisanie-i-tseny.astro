---
import SchedulePage from '../components/schedule/SchedulePage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { formatPrice, getInstitutes, getPage, getScheduleEntries, getTeachers } from '../lib/data';
import { scheduleSupplements } from '../lib/schedule-supplements';

const page = getPage('raspisanie-i-tseny');
const institutes = getInstitutes();
const teachers = getTeachers();
const today = new Date();
today.setHours(0, 0, 0, 0);

const title = page?.seo_title || 'Расписание и цены — ИКПК';
const description = page?.seo_description || 'Расписание семинаров и цены на обучение в ИКПК.';

function slugify(value: string): string {
  return value
    .toLowerCase()
    .replace(/ё/g, 'е')
    .replace(/[^a-zа-я0-9]+/gi, '-')
    .replace(/^-+|-+$/g, '');
}

function formatCalendarDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ru-RU', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  });
}

function pluralizeRu(value: number, one: string, few: string, many: string): string {
  const mod10 = value % 10;
  const mod100 = value % 100;
  if (mod10 === 1 && mod100 !== 11) return one;
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return few;
  return many;
}

function formatDurationLabel(startAt: string, endAt: string, duration: string | number): string {
  const start = new Date(startAt);
  const end = new Date(endAt);
  const diffDays = Math.max(1, Math.round((end.getTime() - start.getTime()) / 86400000) + 1);
  const dayLabel = `${diffDays} ${pluralizeRu(diffDays, 'день', 'дня', 'дней')}`;
  const hoursValue = Number(duration) || 0;
  const hoursLabel = hoursValue > 0 ? `${hoursValue} ${pluralizeRu(hoursValue, 'час', 'часа', 'часов')}` : '-';

  if (startAt === endAt) {
    return `${formatCalendarDate(startAt)} - ${dayLabel} (${hoursLabel})`;
  }

  return `${formatCalendarDate(startAt)} - ${formatCalendarDate(endAt)} - ${dayLabel} (${hoursLabel})`;
}

const baseEntries = getScheduleEntries();
const scheduleIndex = new Set(baseEntries.map((entry) => `${entry.seminar.slug}:${entry.startAt}`));
const entries = [...baseEntries, ...scheduleSupplements.filter((entry) => !scheduleIndex.has(`${entry.seminar.slug}:${entry.startAt}`))]
  .filter((entry) => entry.status === 'active' && new Date(entry.startAt).getTime() >= today.getTime())
  .sort((a, b) => new Date(a.startAt).getTime() - new Date(b.startAt).getTime());

const instituteByName = new Map(institutes.map((institute) => [institute.name, institute]));
const instituteOptionOrder = new Map(institutes.map((institute, index) => [institute.slug, index]));
const visibleInstitutes = entries
  .map((entry) => {
    const institute = instituteByName.get(entry.institute.name);
    return institute ? { label: institute.name, value: institute.slug } : null;
  })
  .filter((value): value is { label: string; value: string } => Boolean(value))
  .filter((value, index, values) => values.findIndex((candidate) => candidate.value === value.value) === index)
  .sort((a, b) => (instituteOptionOrder.get(a.value) ?? 999) - (instituteOptionOrder.get(b.value) ?? 999));

const visibleCities = entries
  .map((entry) => entry.city?.name || '')
  .filter(Boolean)
  .filter((value, index, values) => values.indexOf(value) === index)
  .sort((a, b) => a.localeCompare(b, 'ru'));

const visiblePrograms = entries
  .map((entry) => {
    const institute = instituteByName.get(entry.institute.name);
    return {
      instituteSlug: institute?.slug || '',
      name: entry.program.name,
      slug: entry.program.slug,
    };
  })
  .filter((value, index, values) => values.findIndex((candidate) => candidate.slug === value.slug) === index)
  .sort((a, b) => a.name.localeCompare(b.name, 'ru'));

const cards = entries.map((entry) => {
  const institute = instituteByName.get(entry.institute.name);
  const teacher = entry.teachers?.[0]
    ? teachers.find(
        (candidate) =>
          candidate.slug === String(entry.teachers[0].id) ||
          candidate.legacy_id === String(entry.teachers[0].id) ||
          candidate.name === entry.teachers[0].fullName
      )
    : undefined;
  const teacherName = entry.teachers?.[0]?.fullName || 'Преподаватель уточняется';
  const instituteSlug = institute?.slug || slugify(entry.institute.shortname || entry.institute.name);
  const teacherHref = teacher ? `/${teacher.institute_legacy_id}/prepodavatel/${teacher.slug}` : '';
  const seminarHref = institute
    ? `/${institute.slug}/${entry.program.slug}/${entry.seminar.slug}`
    : '/raspisanie-i-tseny';
  const searchIndex = [
    entry.name,
    teacherName,
    entry.institute.name,
    entry.program.name,
    entry.city?.name || '',
    entry.additionalText || '',
  ].join(' ').toLowerCase();

  return {
    additionalText: entry.additionalText || '',
    cityName: entry.city?.name || 'Уточняется',
    citySlug: slugify(entry.city?.name || 'unknown'),
    dateLabel: formatDurationLabel(entry.startAt, entry.endAt, entry.duration),
    id: entry.id,
    imageAlt: `Изображение для события «${entry.name}»`,
    imageUrl: entry.image?.url || '',
    instituteName: entry.institute.name,
    instituteSlug,
    priceLabel: entry.isFree ? 'Бесплатно' : formatPrice(entry.newPrice),
    programName: entry.program.name,
    programSlug: entry.program.slug,
    registrationHref: entry.registrationFormLink,
    searchIndex,
    teacherHref,
    teacherLabel: entry.institute.shortname === 'ИКПК' ? 'Преподаватель:' : 'Автор:',
    teacherName,
    title: entry.name,
    titleHref: seminarHref,
  };
});
---

<BaseLayout title={title} description={description} newsletterVariant="none">
  <div class="container schedule-page">
    <Breadcrumbs items={[{ label: 'Расписание и цены' }]} />
    <SchedulePage title="Расписание и цены" institutes={visibleInstitutes} programs={visiblePrograms} cities={visibleCities} cards={cards} />
  </div>
</BaseLayout>
