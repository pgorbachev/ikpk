---
// Главная = продвинутый вариант D (верхнее меню). Композиция из
// переиспользуемых секций; заглушки (видео-отзывы, лид-магнит) на проде
// НЕ показываем — они появятся, когда заказчик пришлёт контент.
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroHybrid from '../components/home/sections/HeroHybrid.astro';
import Advantages from '../components/home/sections/Advantages.astro';
import Approach from '../components/home/sections/Approach.astro';
import Programs from '../components/home/sections/Programs.astro';
import Segments from '../components/home/sections/Segments.astro';
import UpcomingSeminars from '../components/home/sections/UpcomingSeminars.astro';
import Teachers from '../components/home/sections/Teachers.astro';
import News from '../components/home/sections/News.astro';
import CtaBand from '../components/home/sections/CtaBand.astro';
import { getPage } from '../lib/data';

const homepage = getPage('homepage');
const title = homepage?.seo_title || 'Обучение прикладной кинезиологии — ИКПК';
const description =
  homepage?.seo_description ||
  'Практико-ориентированное постдипломное обучение прикладной кинезиологии, краниосакральной и висцеральной терапии для врачей, массажистов и реабилитологов. Ближайшие очные семинары в Санкт-Петербурге и Москве.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78126465450',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Санкт-Петербург',
    addressCountry: 'RU',
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <HeroHybrid />
  <Advantages />
  <Approach />
  <Programs />
  <Segments />
  <UpcomingSeminars />
  <Teachers />
  <News />
  <CtaBand />
</BaseLayout>
