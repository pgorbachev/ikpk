---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getInstitutes, getNews, getPromotions, getPage } from '../lib/data';

const institutes = getInstitutes();
const news = getNews().slice(0, 4);
const promotions = getPromotions();
const homepage = getPage('homepage');

const title = homepage?.seo_title || 'ИКПК — Институт клинической прикладной кинезиологии';
const description = homepage?.seo_description || 'Ведущий институт клинической прикладной кинезиологии в РФ и СНГ.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78127482126',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Санкт-Петербург',
    addressCountry: 'RU',
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <h1 class="hero-title">Институт клинической прикладной кинезиологии</h1>
      <p class="hero-subtitle">
        За 20 лет наш институт стал ведущим центром постдипломного образования
        России и СНГ в области холистической медицины.
      </p>
      <a href="/raspisanie-i-tseny" class="btn btn-primary hero-cta">
        Записаться на обучение
      </a>
    </div>
  </section>

  <!-- News -->
  {news.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Новости</h2>
        <div class="grid grid-4 news-grid">
          {news.map((item) => (
            <a href={item.link} class="card news-card" target="_blank" rel="noopener">
              {item.image?.url && (
                <div class="news-card-image">
                  <img src={item.image.url} alt={item.name} loading="lazy" width="300" height="200" />
                </div>
              )}
              <div class="card-body">
                <h3 class="news-card-title">{item.name}</h3>
                <div class="news-card-desc text-small" set:html={item.description} />
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Institutes -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Наши институты</h2>
      <div class="grid grid-3">
        {institutes.map((inst) => (
          <a href={`/${inst.slug}`} class="card institute-card">
            {inst.images?.[0] && (
              <div class="institute-card-image">
                <img src={inst.images[0]} alt={inst.name} loading="lazy" width="400" height="200" />
              </div>
            )}
            <div class="card-body">
              <h3 class="institute-card-title">{inst.name}</h3>
              <p class="text-small">{inst.description_text?.slice(0, 120)}…</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Promotions -->
  {promotions.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Акции и скидки</h2>
        <div class="grid grid-3">
          {promotions.map((promo) => (
            <div class="card promo-card">
              {promo.image?.url && (
                <div class="promo-card-image">
                  <img src={promo.image.url} alt={promo.name} loading="lazy" width="400" height="225" />
                </div>
              )}
              <div class="card-body">
                <h3 class="promo-card-title">{promo.name}</h3>
                <div class="text-small" set:html={promo.description} />
                {promo.link && (
                  <a href={promo.link} class="btn btn-outline promo-link" target="_blank" rel="noopener">
                    Подробнее
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-accent-50) 0%, var(--color-light-100) 100%);
    padding: 4rem 0;
  }

  .hero-inner {
    max-width: 700px;
    text-align: center;
  }

  .hero-title {
    font-size: var(--font-xxxl);
    margin-bottom: 1rem;
    color: var(--color-dark-700);
  }

  .hero-subtitle {
    font-size: var(--font-l);
    color: var(--color-gray-600);
    margin-bottom: 2rem;
  }

  .hero-cta {
    font-size: var(--font-l);
    padding: 0.75rem 2rem;
  }

  .section-alt {
    background-color: var(--color-light-300);
  }

  .news-card,
  .institute-card,
  .promo-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .news-card:hover,
  .institute-card:hover {
    text-decoration: none;
  }

  .news-card-image,
  .institute-card-image,
  .promo-card-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-light-300);
  }

  .news-card-image img,
  .institute-card-image img,
  .promo-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .news-card-title,
  .institute-card-title,
  .promo-card-title {
    font-size: var(--font-m);
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-dark-700);
  }

  .promo-link {
    margin-top: 0.75rem;
    font-size: var(--font-s);
  }
</style>
