---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getInstitutes, getNews, getPromotions, getPage } from '../lib/data';

const institutes = getInstitutes();
const news = getNews().slice(0, 4);
const promotions = getPromotions();
const homepage = getPage('homepage');

const title = homepage?.seo_title || 'ИКПК — Институт клинической прикладной кинезиологии';
const description = homepage?.seo_description || 'Ведущий институт клинической прикладной кинезиологии в РФ и СНГ.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78126465450',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Санкт-Петербург',
    addressCountry: 'RU',
  },
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">Институт клинической прикладной кинезиологии</h1>
        <p class="hero-subtitle">
          За 20 лет наш институт стал ведущим центром постдипломного образования
          России и СНГ в области холистической медицины. Эксклюзивное представительство
          мировых лидеров в этой области — Институтов Апледжера и Барраля — предоставляет
          нашим уважаемым студентам ИКПК возможность учиться по международным стандартам.
        </p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary hero-cta">
          Записаться на обучение
        </a>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <img src="/logo-icon.svg" alt="" class="hero-logo" width="120" height="124" />
      </div>
    </div>
  </section>

  <!-- Преимущества -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши преимущества</h2>
      <div class="grid grid-3 advantages-grid">
        <div class="card adv-card">
          <div class="card-body">
            <h3 class="adv-card-title">Наш многолетний опыт в образовании</h3>
            <p class="text-small">Подготовка квалифицированных специалистов в медицине — сложная и ответственная задача. У нас получается делать это лучше других, потому что наработали годами проверенные методики и продолжаем оттачивать их.</p>
          </div>
        </div>
        <div class="card adv-card">
          <div class="card-body">
            <h3 class="adv-card-title">Сотрудничество с зарубежными институтами</h3>
            <p class="text-small">ИКПК — единственный официальный представитель институтов Апледжера и Барраля в России, предлагающий уникальные методики ведущих специалистов. Это даёт вам возможность обучаться по мировым стандартам.</p>
          </div>
        </div>
        <div class="card adv-card">
          <div class="card-body">
            <h3 class="adv-card-title">Настоящие преподаватели – ключ к успеху</h3>
            <p class="text-small">Чтобы стать хорошим преподавателем, недостаточно быть просто отличным врачом. Поэтому в педагогическом штате ИКПК — лучшие из лучших, создавшие авторские программы и щедро делящиеся своими знаниями и опытом.</p>
          </div>
        </div>
        <div class="card adv-card">
          <div class="card-body">
            <h3 class="adv-card-title">Документы об образовании для наших студентов</h3>
            <p class="text-small">Студенты с базовым медицинским образованием получают удостоверения о повышении квалификации с внесением сведений в ФИС ФРДО. Они также имеют возможность получить единицы трудоёмкости (ЗЕТ, баллы НМО).</p>
          </div>
        </div>
        <div class="card adv-card">
          <div class="card-body">
            <h3 class="adv-card-title">Издательство медицинской литературы</h3>
            <p class="text-small">Издательский дом ИКПК занимается лицензированным переводом и изданием на русском языке научной и учебной литературы по остеопатии и прикладной кинезиологии. Большинство книг изданы в России впервые.</p>
          </div>
        </div>
        <div class="card adv-card">
          <div class="card-body">
            <h3 class="adv-card-title">Практика в нашем медицинском центре</h3>
            <p class="text-small">В нашем медицинском центре студенты могут под руководством опытных преподавателей совершенствовать знания, полученные в процессе обучения. Такой аналог интернатуры в области холистической медицины доступен только здесь.</p>
          </div>
        </div>
      </div>
      <div class="adv-cta">
        <p class="adv-cta-lead">Готовы к нам присоединиться?</p>
        <p class="adv-cta-sub">Кликайте на кнопку, выбирайте направление и записывайтесь к нам на обучение!</p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary">Записаться на обучение</a>
      </div>
    </div>
  </section>

  <!-- Подход + Статистика -->
  <section class="section section-alt">
    <div class="container approach-wrap">
      <div class="approach-text">
        <h2 class="section-title">Наш подход к обучению</h2>
        <p>В течение каждого курса, большую часть времени, мы уделяем практической отработке приобретенных навыков и знаний. Это ключевой подход, который позволяет нашим студентам успешно применять полученные знания в реальных ситуациях и готовиться к профессиональной деятельности на самом высоком уровне.</p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary approach-cta">Записаться на обучение</a>
      </div>
      <div class="approach-visual" aria-hidden="true">
        <img src="/logo-icon.svg" alt="" class="approach-logo" width="80" height="82" />
      </div>
      <div class="grid grid-3 stats-grid">
        <div class="stat-card">
          <span class="stat-number">14000+</span>
          <span class="stat-label">специалистов обучили</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">&gt;&nbsp;20 лет</span>
          <span class="stat-label">обучаем новых специалистов</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1500+</span>
          <span class="stat-label">получили государственную аккредитацию</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Программы -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши программы</h2>
      <div class="grid grid-3">
        <a href="/institut-klinicheskoy-prikladnoy-kineziologii" class="card prog-card">
          <div class="card-body">
            <h3 class="prog-card-title">Программы обучения Института клинической прикладной кинезиологии</h3>
            <p class="text-small">Востребованные программы в области остеопатии и прикладной кинезиологии в соответствии с международными стандартами. Институт имеет лицензию на образовательную деятельность №3471 от 13.06.2018.</p>
          </div>
        </a>
        <a href="/institut-apledzhera" class="card prog-card">
          <div class="card-body">
            <h3 class="prog-card-title">Программы обучения Института Апледжера</h3>
            <p class="text-small">Программы были разработаны доктором остеопатической медицины Джоном Апледжером как метод коррекции состояния кранио-сакральной системы, отвечающей за выработку, циркуляцию и реабсорбцию спинномозговой жидкости.</p>
          </div>
        </a>
        <a href="/institut-barralya" class="card prog-card">
          <div class="card-body">
            <h3 class="prog-card-title">Программы обучения Института Барраля</h3>
            <p class="text-small">Французский физиотерапевт и остеопат Жан-Пьер Барраль разработал инновационные способы диагностики и лечения патологий внутренних органов и систем человеческого организма методом висцеральных, невральных манипуляций.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- News -->
  {news.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-title">Новости</h2>
        <div class="grid grid-4 news-grid">
          {news.map((item) => (
            <a href={item.link} class="card news-card" target="_blank" rel="noopener">
              {item.image?.url && (
                <div class="news-card-image">
                  <img src={item.image.url} alt={item.name} loading="lazy" width="300" height="200" />
                </div>
              )}
              <div class="card-body">
                <h3 class="news-card-title">{item.name}</h3>
                <div class="news-card-desc text-small" set:html={item.description} />
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Institutes -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши институты</h2>
      <div class="grid grid-3">
        {institutes.map((inst) => (
          <a href={`/${inst.slug}`} class="card institute-card">
            {inst.images?.[0] && (
              <div class="institute-card-image">
                <img src={inst.images[0]} alt={inst.name} loading="lazy" width="400" height="200" />
              </div>
            )}
            <div class="card-body">
              <h3 class="institute-card-title">{inst.name}</h3>
              <p class="text-small">{inst.description_text?.slice(0, 120)}…</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Promotions -->
  {promotions.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Акции и скидки</h2>
        <div class="grid grid-3">
          {promotions.map((promo) => (
            <div class="card promo-card">
              {promo.image?.url && (
                <div class="promo-card-image">
                  <img src={promo.image.url} alt={promo.name} loading="lazy" width="400" height="225" />
                </div>
              )}
              <div class="card-body">
                <h3 class="promo-card-title">{promo.name}</h3>
                <div class="text-small" set:html={promo.description} />
                {promo.link && (
                  <a href={promo.link} class="btn btn-outline promo-link" target="_blank" rel="noopener">
                    Подробнее
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-accent-50) 0%, var(--color-light-100) 100%);
    padding: 4rem 0;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 960px;
  }

  .hero-content {
    flex: 1;
  }

  .hero-visual {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .hero-logo {
    opacity: 0.9;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.08));
  }

  .hero-title {
    font-size: var(--font-xxxl);
    margin-bottom: 1rem;
    color: var(--color-dark-700);
  }

  .hero-subtitle {
    font-size: var(--font-l);
    color: var(--color-gray-600);
    margin-bottom: 2rem;
  }

  .hero-cta {
    font-size: var(--font-l);
    padding: 0.75rem 2rem;
  }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      text-align: center;
    }
    .hero-visual {
      width: 120px;
      height: 120px;
      order: -1;
    }
    .hero-logo {
      width: 80px;
      height: 82px;
    }
  }

  .section-alt {
    background-color: var(--color-light-300);
  }

  .news-card,
  .institute-card,
  .promo-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .news-card:hover,
  .institute-card:hover {
    text-decoration: none;
  }

  .news-card-image,
  .institute-card-image,
  .promo-card-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-light-300);
  }

  .news-card-image img,
  .institute-card-image img,
  .promo-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .news-card-title,
  .institute-card-title,
  .promo-card-title {
    font-size: var(--font-m);
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-dark-700);
  }

  .promo-link {
    margin-top: 0.75rem;
    font-size: var(--font-s);
  }

  /* Преимущества */
  .adv-card-title {
    font-size: var(--font-m);
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-accent-600);
  }

  .adv-cta {
    margin-top: 2.5rem;
    text-align: center;
  }

  .adv-cta-lead {
    font-size: var(--font-xl);
    font-weight: 700;
    color: var(--color-dark-700);
    margin-bottom: 0.25rem;
  }

  .adv-cta-sub {
    color: var(--color-gray-600);
    margin-bottom: 1.25rem;
  }

  /* Подход + Статистика */
  .approach-wrap {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .approach-text {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 2rem;
  }

  .approach-text .section-title {
    width: 100%;
  }

  .approach-text p {
    color: var(--color-gray-600);
    margin-bottom: 1.5rem;
    max-width: 620px;
    flex: 1;
  }

  .approach-visual {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--color-light-100);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
  }

  .approach-logo {
    opacity: 0.7;
  }

  .approach-cta {
    display: inline-block;
    width: 100%;
  }

  .stats-grid {
    margin-top: 0;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--color-light-100);
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
  }

  .stat-number {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-accent-500);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: var(--font-s);
    color: var(--color-gray-600);
    line-height: 1.4;
  }

  /* Программы */
  .prog-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .prog-card:hover {
    text-decoration: none;
  }

  .prog-card-title {
    font-size: var(--font-m);
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-accent-600);
  }
</style>
