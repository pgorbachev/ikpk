---
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaCard from '../components/ui/MediaCard.astro';
import { getInstitutes, getNews, getPromotions, getPage } from '../lib/data';

const institutes = getInstitutes();
const news = getNews().slice(0, 4);
const promotions = getPromotions();
const homepage = getPage('homepage');
const advantages = [
  {
    icon: '/adv-icon-1.svg',
    title: 'Наш многолетний опыт в образовании',
    text: 'Подготовка квалифицированных специалистов в медицине — сложная и ответственная задача. У нас получается делать это лучше других, потому что наработали годами проверенные методики и продолжаем оттачивать их.',
  },
  {
    icon: '/adv-icon-2.svg',
    title: 'Сотрудничество с зарубежными институтами',
    text: 'ИКПК — единственный официальный представитель институтов Апледжера и Барраля в России, предлагающий уникальные методики ведущих специалистов. Это даёт вам возможность обучаться по мировым стандартам.',
  },
  {
    icon: '/adv-icon-3.svg',
    title: 'Настоящие преподаватели – ключ к успеху',
    text: 'Чтобы стать хорошим преподавателем, недостаточно быть просто отличным врачом. Поэтому в педагогическом штате ИКПК — лучшие из лучших, создавшие авторские программы и щедро делящиеся своими знаниями и опытом.',
  },
  {
    icon: '/adv-icon-4.svg',
    title: 'Документы об образовании для наших студентов',
    text: 'Студенты с базовым медицинским образованием получают удостоверения о повышении квалификации с внесением сведений в ФИС ФРДО. Они также имеют возможность получить единицы трудоёмкости (ЗЕТ, баллы НМО).',
  },
  {
    icon: '/adv-icon-5.svg',
    title: 'Издательство медицинской литературы',
    text: 'Издательский дом ИКПК занимается лицензированным переводом и изданием на русском языке научной и учебной литературы по остеопатии и прикладной кинезиологии. Большинство книг изданы в России впервые.',
  },
  {
    icon: '/adv-icon-6.svg',
    title: 'Практика в нашем медицинском центре',
    text: 'В нашем медицинском центре студенты могут под руководством опытных преподавателей совершенствовать знания, полученные в процессе обучения. Такой аналог интернатуры в области холистической медицины доступен только здесь.',
  },
];

const title = homepage?.seo_title || 'ИКПК — Институт клинической прикладной кинезиологии';
const description = homepage?.seo_description || 'Ведущий институт клинической прикладной кинезиологии в РФ и СНГ.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78126465450',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Санкт-Петербург',
    addressCountry: 'RU',
  },
};
---

<BaseLayout title={title} description={description} schema={schema} preloadHero={true}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">Институт клинической прикладной кинезиологии</h1>
        <p class="hero-subtitle">
          За 20 лет наш институт стал ведущим центром постдипломного образования
          России и СНГ в области холистической медицины. Эксклюзивное представительство
          мировых лидеров в этой области — Институтов Апледжера и Барраля — предоставляет
          нашим уважаемым студентам ИКПК возможность учиться по международным стандартам.
        </p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary hero-cta">
          Записаться на обучение
        </a>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <img
          src="/hero-main.svg"
          alt=""
          class="hero-illustration"
          loading="eager"
          fetchpriority="high"
          width="516"
          height="504"
        />
      </div>
    </div>
  </section>

  <!-- Преимущества -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши преимущества</h2>
      <div class="grid grid-3 advantages-grid">
        {advantages.map((item) => (
          <div class="card adv-card">
            <div class="card-body">
              <div class="adv-card-head">
                <img src={item.icon} alt="" class="adv-card-icon" width="36" height="36" loading="lazy" />
                <h3 class="adv-card-title">{item.title}</h3>
              </div>
              <p class="text-small">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="adv-cta">
        <p class="adv-cta-lead">Готовы к нам присоединиться?</p>
        <p class="adv-cta-sub">Кликайте на кнопку, выбирайте направление и записывайтесь к нам на обучение!</p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary">Записаться на обучение</a>
      </div>
    </div>
  </section>

  <!-- Подход + Статистика -->
  <section class="section section-alt">
    <div class="container approach-wrap">
      <div class="approach-text">
        <h2 class="section-title">Наш подход к обучению</h2>
        <p>В течение каждого курса, большую часть времени, мы уделяем практической отработке приобретенных навыков и знаний. Это ключевой подход, который позволяет нашим студентам успешно применять полученные знания в реальных ситуациях и готовиться к профессиональной деятельности на самом высоком уровне.</p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary approach-cta">Записаться на обучение</a>
      </div>
      <div class="approach-visual" aria-hidden="true">
        <img
          src="/approach-learning.svg"
          alt=""
          class="approach-illustration"
          loading="lazy"
          width="450"
          height="370"
        />
      </div>
      <div class="grid grid-3 stats-grid">
        <div class="stat-card">
          <span class="stat-number">14000+</span>
          <span class="stat-label">специалистов обучили</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">&gt;&nbsp;20 лет</span>
          <span class="stat-label">обучаем новых специалистов</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1500+</span>
          <span class="stat-label">получили государственную аккредитацию</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Программы -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши программы</h2>
      <div class="grid grid-3">
        <MediaCard
          href="/institut-klinicheskoy-prikladnoy-kineziologii"
          title="Программы обучения Института клинической прикладной кинезиологии"
          accentTitle={true}
          className="prog-card"
        >
          <p class="text-small">Востребованные программы в области остеопатии и прикладной кинезиологии в соответствии с международными стандартами. Институт имеет лицензию на образовательную деятельность №3471 от 13.06.2018.</p>
        </MediaCard>
        <MediaCard
          href="/institut-apledzhera"
          title="Программы обучения Института Апледжера"
          accentTitle={true}
          className="prog-card"
        >
          <p class="text-small">Программы были разработаны доктором остеопатической медицины Джоном Апледжером как метод коррекции состояния кранио-сакральной системы, отвечающей за выработку, циркуляцию и реабсорбцию спинномозговой жидкости.</p>
        </MediaCard>
        <MediaCard
          href="/institut-barralya"
          title="Программы обучения Института Барраля"
          accentTitle={true}
          className="prog-card"
        >
          <p class="text-small">Французский физиотерапевт и остеопат Жан-Пьер Барраль разработал инновационные способы диагностики и лечения патологий внутренних органов и систем человеческого организма методом висцеральных, невральных манипуляций.</p>
        </MediaCard>
      </div>
    </div>
  </section>

  <!-- News -->
  {news.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-title">Новости</h2>
        <div class="grid grid-4 news-grid">
          {news.map((item) => (
            <MediaCard
              href={item.link}
              title={item.name}
              image={item.image?.url}
              imageAlt={item.name}
              imageRatio="3 / 2"
              target="_blank"
              rel="noopener"
              className="news-card"
            >
              <div class="news-card-desc text-small" set:html={item.description} />
            </MediaCard>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Institutes -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши институты</h2>
      <div class="grid grid-3">
        {institutes.map((inst) => (
          <MediaCard
            href={`/${inst.slug}`}
            title={inst.name}
            image={inst.images?.[0]}
            imageAlt={inst.name}
            imageRatio="3 / 2"
            className="institute-card"
          >
            <p class="text-small">{inst.description_text?.slice(0, 120)}…</p>
          </MediaCard>
        ))}
      </div>
    </div>
  </section>

  <!-- Promotions -->
  {promotions.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Акции и скидки</h2>
        <div class="grid grid-3">
          {promotions.map((promo) => (
            <MediaCard
              title={promo.name}
              image={promo.image?.url}
              imageAlt={promo.name}
              imageRatio="3 / 2"
              className="promo-card"
            >
              <div class="text-small" set:html={promo.description} />
              {promo.link && (
                <a href={promo.link} class="btn btn-outline promo-link" target="_blank" rel="noopener">
                  Подробнее
                </a>
              )}
            </MediaCard>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-accent-50) 0%, var(--color-light-100) 100%);
    padding: 4rem 0;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 960px;
  }

  .hero-content {
    flex: 1;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 420px);
  }

  .hero-illustration {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-title {
    font-size: var(--font-xxxl);
    margin-bottom: 1rem;
    color: var(--color-dark-700);
  }

  .hero-subtitle {
    font-size: var(--font-l);
    color: var(--color-gray-600);
    margin-bottom: 2rem;
  }

  .hero-cta {
    font-size: var(--font-l);
    padding: 0.75rem 2rem;
  }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      text-align: center;
    }
    .hero-visual {
      width: min(100%, 300px);
      order: -1;
    }
  }

  .section-alt {
    background-color: var(--color-light-300);
  }

  .promo-link {
    margin-top: 0.75rem;
    font-size: var(--font-s);
  }

  /* Преимущества */
  .adv-card-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.625rem;
  }

  .adv-card-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .adv-card-title {
    font-size: var(--font-m);
    font-weight: 600;
    margin-bottom: 0;
    color: var(--color-accent-600);
  }

  .adv-cta {
    margin-top: 2.5rem;
    text-align: center;
  }

  .adv-cta-lead {
    font-size: var(--font-xl);
    font-weight: 700;
    color: var(--color-dark-700);
    margin-bottom: 0.25rem;
  }

  .adv-cta-sub {
    color: var(--color-gray-600);
    margin-bottom: 1.25rem;
  }

  /* Подход + Статистика */
  .approach-wrap {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .approach-text {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 2rem;
  }

  .approach-text .section-title {
    width: 100%;
  }

  .approach-text p {
    color: var(--color-gray-600);
    margin-bottom: 1.5rem;
    max-width: 620px;
    flex: 1;
  }

  .approach-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 450px);
    margin: 0 auto;
  }

  .approach-illustration {
    width: 100%;
    height: auto;
    display: block;
  }

  .approach-cta {
    display: inline-block;
    width: 100%;
  }

  .stats-grid {
    margin-top: 0;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--color-light-100);
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
  }

  .stat-number {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-accent-500);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: var(--font-s);
    color: var(--color-gray-600);
    line-height: 1.4;
  }

</style>
