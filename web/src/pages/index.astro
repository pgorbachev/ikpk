---
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaCard from '../components/ui/MediaCard.astro';
import FeatureCard from '../components/home/FeatureCard.astro';
import { getInstitutes, getNews, getPage, cleanBodyHtml, relForExternalUrl } from '../lib/data';

const news = getNews();
const institutes = getInstitutes();
const homepage = getPage('homepage');
const advantages = [
  {
    icon: '/adv-icon-1.svg',
    title: 'Наш многолетний опыт в образовании',
    text: 'Подготовка квалифицированных специалистов в медицине — сложная и ответственная задача. У нас получается делать это лучше других, потому что наработали годами проверенные методики и продолжаем оттачивать их.',
  },
  {
    icon: '/adv-icon-2.svg',
    title: 'Сотрудничество с зарубежными институтами',
    text: 'ИКПК — единственный официальный представитель институтов Апледжера и Барраля в России, предлагающий уникальные методики ведущих специалистов. Это даёт вам возможность обучаться по мировым стандартам.',
  },
  {
    icon: '/adv-icon-3.svg',
    title: 'Настоящие преподаватели – ключ к успеху',
    text: 'Чтобы стать хорошим преподавателем, недостаточно быть просто отличным врачом. Поэтому в педагогическом штате ИКПК — лучшие из лучших, создавшие авторские программы и щедро делящиеся своими знаниями и опытом.',
  },
  {
    icon: '/adv-icon-4.svg',
    title: 'Документы об образовании для наших студентов',
    text: 'Студенты с базовым медицинским образованием получают удостоверения о повышении квалификации с внесением сведений в ФИС ФРДО. Они также имеют возможность получить единицы трудоёмкости (ЗЕТ, баллы НМО).',
  },
  {
    icon: '/adv-icon-5.svg',
    title: 'Издательство медицинской литературы',
    text: 'Издательский дом ИКПК занимается лицензированным переводом и изданием на русском языке научной и учебной литературы по остеопатии и прикладной кинезиологии. Большинство книг изданы в России впервые.',
  },
  {
    icon: '/adv-icon-6.svg',
    title: 'Практика в нашем медицинском центре',
    text: 'В нашем медицинском центре студенты могут под руководством опытных преподавателей совершенствовать знания, полученные в процессе обучения. Такой аналог интернатуры в области холистической медицины доступен только здесь.',
  },
];

const title = homepage?.seo_title || 'ИКПК — Институт клинической прикладной кинезиологии';
const description = homepage?.seo_description || 'Ведущий институт клинической прикладной кинезиологии в РФ и СНГ.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Институт клинической прикладной кинезиологии',
  url: 'https://ikpk.su',
  telephone: '+78126465450',
  email: 'info@ikpk.su',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Санкт-Петербург',
    addressCountry: 'RU',
  },
};

const ikpkInstitute = institutes.find((inst) => inst.slug === 'institut-klinicheskoy-prikladnoy-kineziologii');
const upledgerInstitute = institutes.find((inst) => inst.slug === 'institut-apledzhera');
const barralInstitute = institutes.find((inst) => inst.slug === 'institut-barralya');
---

<BaseLayout title={title} description={description} schema={schema} preloadHero={true}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">Институт клинической прикладной кинезиологии</h1>
        <p class="hero-subtitle">
          За 20 лет наш институт стал ведущим центром постдипломного образования
          России и СНГ в области холистической медицины. Эксклюзивное представительство
          мировых лидеров в этой области — Институтов Апледжера и Барраля — предоставляет
          нашим уважаемым студентам ИКПК возможность учиться по международным стандартам.
        </p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary hero-cta">
          Записаться на обучение
        </a>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <img
          src="/hero-main.svg"
          alt=""
          class="hero-illustration"
          loading="eager"
          fetchpriority="high"
          width="516"
          height="504"
        />
      </div>
    </div>
  </section>

  <!-- Преимущества -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши преимущества</h2>
      <div class="grid grid-3 advantages-grid">
        {advantages.map((item) => (
          <FeatureCard icon={item.icon} title={item.title} text={item.text} />
        ))}
      </div>
      <div class="adv-cta">
        <div class="adv-cta-shell">
          <div class="adv-cta-copy">
            <p class="adv-cta-lead">Готовы к нам присоединиться?</p>
            <p class="adv-cta-sub">Выбирайте направление обучения и записывайтесь на ближайший поток ИКПК.</p>
          </div>
          <a href="/raspisanie-i-tseny" class="btn btn-primary adv-cta-btn">Записаться на обучение</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Подход + Статистика -->
  <section class="section section-alt">
    <div class="container approach-wrap">
      <div class="approach-text">
        <h2 class="section-title">Наш подход к обучению</h2>
        <p>В течение каждого курса, большую часть времени, мы уделяем практической отработке приобретенных навыков и знаний. Это ключевой подход, который позволяет нашим студентам успешно применять полученные знания в реальных ситуациях и готовиться к профессиональной деятельности на самом высоком уровне.</p>
        <a href="/raspisanie-i-tseny" class="btn btn-primary approach-cta">Записаться на обучение</a>
      </div>
      <div class="approach-visual" aria-hidden="true">
        <img
          src="/approach-learning.svg"
          alt=""
          class="approach-illustration"
          loading="lazy"
          width="450"
          height="370"
        />
      </div>
      <div class="grid grid-3 stats-grid">
        <div class="stat-card">
          <span class="stat-number">14000+</span>
          <span class="stat-label">специалистов обучили</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">&gt;&nbsp;20 лет</span>
          <span class="stat-label">обучаем новых специалистов</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">1500+</span>
          <span class="stat-label">получили государственную аккредитацию</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Программы -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Наши программы</h2>
      <div class="grid grid-3">
        <MediaCard
          href="/institut-klinicheskoy-prikladnoy-kineziologii"
          title="Программы обучения Института клинической прикладной кинезиологии"
          image={ikpkInstitute?.images?.[0]}
          imageAlt="Эмблема Института клинической прикладной кинезиологии"
          imageRatio="5 / 2"
          imageFit="contain"
          mediaClassName="program-logo-media"
          accentTitle={true}
          className="prog-card institute-card"
        >
          <p class="text-small">Востребованные программы в области остеопатии и прикладной кинезиологии в соответствии с международными стандартами. Институт имеет лицензию на образовательную деятельность №3471 от 13.06.2018.</p>
        </MediaCard>
        <MediaCard
          href="/institut-apledzhera"
          title="Программы обучения Института Апледжера"
          image={upledgerInstitute?.images?.[0]}
          imageAlt="Эмблема Института Апледжера"
          imageRatio="5 / 2"
          imageFit="contain"
          mediaClassName="program-logo-media"
          accentTitle={true}
          className="prog-card institute-card"
        >
          <p class="text-small">Программы были разработаны доктором остеопатической медицины Джоном Апледжером как метод коррекции состояния кранио-сакральной системы, отвечающей за выработку, циркуляцию и реабсорбцию спинномозговой жидкости.</p>
        </MediaCard>
        <MediaCard
          href="/institut-barralya"
          title="Программы обучения Института Барраля"
          image={barralInstitute?.images?.[0]}
          imageAlt="Эмблема Института Барраля"
          imageRatio="5 / 2"
          imageFit="contain"
          mediaClassName="program-logo-media"
          accentTitle={true}
          className="prog-card institute-card"
        >
          <p class="text-small">Французский физиотерапевт и остеопат Жан-Пьер Барраль разработал инновационные способы диагностики и лечения патологий внутренних органов и систем человеческого организма методом висцеральных, невральных манипуляций.</p>
        </MediaCard>
      </div>
    </div>
  </section>

  <!-- News -->
  {news.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-title">Новости</h2>
        <div class="news-slider" data-news-slider>
          <button type="button" class="news-nav-btn" aria-label="Предыдущий слайд" data-news-prev>
            <svg class="news-nav-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M12.5 4.5L7 10l5.5 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div class="news-viewport" data-news-viewport>
            <div class="news-track" data-news-track>
              {news.map((item) => (
                <MediaCard
                  href={item.link}
                  title={item.name}
                  image={item.image?.url}
                  imageAlt={item.name}
                  imageRatio="3 / 2"
                  target="_blank"
                  rel={[...new Set(['noopener', ...(relForExternalUrl(item.link) ?? [])])].join(' ')}
                  className="news-card"
                >
                  <div class="news-card-desc text-small" set:html={cleanBodyHtml(item.description)} />
                </MediaCard>
              ))}
            </div>
          </div>
          <button type="button" class="news-nav-btn" aria-label="Следующий слайд" data-news-next>
            <svg class="news-nav-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M7.5 4.5L13 10l-5.5 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-accent-50) 0%, var(--color-light-100) 100%);
    padding: 4rem 0;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 960px;
  }

  .hero-content {
    flex: 1;
  }

  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 420px);
  }

  .hero-illustration {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero-title {
    font-size: var(--font-xxxl);
    margin-bottom: 1rem;
    color: var(--color-dark-700);
  }

  .hero-subtitle {
    font-size: var(--font-l);
    color: var(--color-gray-600);
    margin-bottom: 2rem;
  }

  .hero-cta {
    font-size: var(--font-l);
    padding: 0.75rem 2rem;
  }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      text-align: center;
    }
    .hero-visual {
      width: min(100%, 300px);
      order: -1;
    }
  }

  .section-alt {
    background-color: var(--color-light-300);
  }

  .news-slider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .news-viewport {
    min-width: 0;
    flex: 1;
    overflow: hidden;
  }

  .news-track {
    --news-visible: 4;
    display: grid;
    grid-template-columns: repeat(var(--news-visible), minmax(0, 1fr));
    gap: 1rem;
  }

  :global(.news-card) {
    display: none;
    min-width: 0;
  }

  :global(.news-card.is-visible) {
    display: block;
  }

  .news-nav-btn {
    width: 40px;
    border: 1px solid var(--color-gray-250);
    border-radius: var(--radius-s);
    background: var(--color-light-100);
    color: var(--color-dark-700);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
  }

  .news-nav-btn:hover {
    background: #f5f5f5;
    border-color: #cdcdcd;
  }

  .news-nav-icon {
    width: 18px;
    height: 18px;
  }

  :global(.news-card .card-body) {
    padding: 0.9rem 1rem 1rem;
  }

  :global(.news-card .media-card-title) {
    font-size: 0.94rem;
    margin-bottom: 0.4rem;
  }

  .news-card-desc {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.prog-card) {
    border-color: var(--color-gray-250);
    box-shadow: none;
  }

  :global(.prog-card:hover) {
    border-color: #cfcfcf;
    box-shadow: var(--shadow-s);
  }

  :global(.prog-card .card-body) {
    padding: 1rem 1rem 1.1rem;
  }

  :global(.prog-card .media-card-title) {
    font-size: 0.95rem;
    line-height: 1.35;
    min-height: 3.1em;
  }

  :global(.program-logo-media) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.8rem;
    border-bottom: 1px solid var(--color-gray-150);
    background: #fcfcfc;
  }

  :global(.program-logo-media img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .news-track {
      --news-visible: 2;
    }
  }

  @media (max-width: 640px) {
    .news-slider {
      gap: 0.5rem;
    }

    .news-nav-btn {
      width: 34px;
    }

    .news-track {
      --news-visible: 1;
    }
  }

  /* Преимущества */
  .advantages-grid {
    gap: 1.2rem;
  }

  .adv-cta {
    margin-top: 2.25rem;
  }

  .adv-cta-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.35rem;
    padding: 1.25rem 1.4rem;
    border-radius: 20px;
    background: linear-gradient(135deg, #46554f 0%, #3d4b46 100%);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.16);
  }

  .adv-cta-copy {
    max-width: 640px;
  }

  .adv-cta-lead {
    font-size: 1.45rem;
    font-weight: 600;
    color: #f7fbf9;
    margin-bottom: 0.35rem;
    line-height: 1.25;
  }

  .adv-cta-sub {
    color: rgba(245, 250, 248, 0.88);
    margin: 0;
    line-height: 1.5;
    font-size: var(--font-m);
  }

  .adv-cta-btn {
    flex-shrink: 0;
    border-color: rgba(255, 255, 255, 0.26);
    box-shadow: none;
  }

  @media (max-width: 860px) {
    .adv-cta-shell {
      flex-direction: column;
      align-items: flex-start;
    }

    .adv-cta-btn {
      width: 100%;
      text-align: center;
    }
  }

  /* Подход + Статистика */
  .approach-wrap {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .approach-text {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 2rem;
  }

  .approach-text .section-title {
    width: 100%;
  }

  .approach-text p {
    color: var(--color-gray-600);
    margin-bottom: 1.5rem;
    max-width: 620px;
    flex: 1;
  }

  .approach-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 450px);
    margin: 0 auto;
  }

  .approach-illustration {
    width: 100%;
    height: auto;
    display: block;
  }

  .approach-cta {
    display: inline-block;
    width: 100%;
  }

  .stats-grid {
    margin-top: 0;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--color-light-100);
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
  }

  .stat-number {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-accent-500);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: var(--font-s);
    color: var(--color-gray-600);
    line-height: 1.4;
  }

</style>

<script>
  const slider = document.querySelector<HTMLElement>('[data-news-slider]');
  const track = slider?.querySelector<HTMLElement>('[data-news-track]');
  const prevBtn = slider?.querySelector<HTMLButtonElement>('[data-news-prev]');
  const nextBtn = slider?.querySelector<HTMLButtonElement>('[data-news-next]');

  if (slider && track && prevBtn && nextBtn) {
    const cards = Array.from(track.children) as HTMLElement[];
    let startIndex = 0;

    const getVisibleCount = () => {
      const width = window.innerWidth;
      if (width <= 680) return 1;
      if (width <= 1024) return 2;
      return 4;
    };

    const render = () => {
      if (cards.length === 0) return;
      const visibleCount = Math.min(getVisibleCount(), cards.length);
      track.style.setProperty('--news-visible', String(visibleCount));
      track.setAttribute('data-start-index', String(startIndex));
      track.setAttribute('data-visible-count', String(visibleCount));
      cards.forEach((card, idx) => {
        const relative = (idx - startIndex + cards.length) % cards.length;
        card.style.order = String(relative);
        card.classList.toggle('is-visible', relative < visibleCount);
      });
    };

    prevBtn.addEventListener('click', () => {
      if (cards.length === 0) return;
      startIndex = (startIndex - 1 + cards.length) % cards.length;
      render();
    });

    nextBtn.addEventListener('click', () => {
      if (cards.length === 0) return;
      startIndex = (startIndex + 1) % cards.length;
      render();
    });

    window.addEventListener('resize', render);
    render();
  }
</script>
