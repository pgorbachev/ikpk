---
// Секция «Наши программы» — 3 института. Извлечена из index.astro.
import MediaCard from '../../ui/MediaCard.astro';
import { getInstitutes } from '../../../lib/data';

const institutes = getInstitutes();
const ikpkInstitute = institutes.find((inst) => inst.slug === 'institut-klinicheskoy-prikladnoy-kineziologii');
const upledgerInstitute = institutes.find((inst) => inst.slug === 'institut-apledzhera');
const barralInstitute = institutes.find((inst) => inst.slug === 'institut-barralya');
---
<section class="section" data-reveal>
  <div class="container">
    <h2 class="section-title">Наши программы</h2>
    <div class="grid grid-3">
      <MediaCard
        href="/institut-klinicheskoy-prikladnoy-kineziologii"
        title="Программы обучения Института клинической прикладной кинезиологии"
        image={ikpkInstitute?.images?.[0]}
        imageAlt="Эмблема Института клинической прикладной кинезиологии"
        imageRatio="5 / 2"
        imageFit="contain"
        mediaClassName="program-logo-media"
        accentTitle={true}
        className="prog-card institute-card"
      >
        <p class="text-small">Востребованные программы в области остеопатии и прикладной кинезиологии в соответствии с международными стандартами. Институт имеет лицензию на образовательную деятельность №3471 от 13.06.2018.</p>
      </MediaCard>
      <MediaCard
        href="/institut-apledzhera"
        title="Программы обучения Института Апледжера"
        image={upledgerInstitute?.images?.[0]}
        imageAlt="Эмблема Института Апледжера"
        imageRatio="5 / 2"
        imageFit="contain"
        mediaClassName="program-logo-media"
        accentTitle={true}
        className="prog-card institute-card"
      >
        <p class="text-small">Программы были разработаны доктором остеопатической медицины Джоном Апледжером как метод коррекции состояния кранио-сакральной системы, отвечающей за выработку, циркуляцию и реабсорбцию спинномозговой жидкости.</p>
      </MediaCard>
      <MediaCard
        href="/institut-barralya"
        title="Программы обучения Института Барраля"
        image={barralInstitute?.images?.[0]}
        imageAlt="Эмблема Института Барраля"
        imageRatio="5 / 2"
        imageFit="contain"
        mediaClassName="program-logo-media"
        accentTitle={true}
        className="prog-card institute-card"
      >
        <p class="text-small">Французский физиотерапевт и остеопат Жан-Пьер Барраль разработал инновационные способы диагностики и лечения патологий внутренних органов и систем человеческого организма методом висцеральных, невральных манипуляций.</p>
      </MediaCard>
    </div>
  </div>
</section>

<style>
  :global(.prog-card) {
    border-color: var(--color-gray-250);
    box-shadow: none;
  }

  :global(.prog-card:hover) {
    border-color: #cfcfcf;
    box-shadow: var(--shadow-s);
  }

  :global(.prog-card .card-body) {
    padding: 1rem 1rem 1.1rem;
  }

  :global(.prog-card .media-card-title) {
    font-size: 0.95rem;
    line-height: 1.35;
    min-height: 3.1em;
  }

  :global(.program-logo-media) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.8rem;
    border-bottom: 1px solid var(--color-gray-150);
    background: #fcfcfc;
  }

  :global(.program-logo-media img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
