---
// Пометка «черновой блок» для секций, заблокированных контентом заказчика.
// Единый стиль — виден только в превью вариантов.
interface Props {
  text: string;
}
const { text } = Astro.props;
---
<p class="placeholder-note">⚠ {text}</p>

<style>
  .placeholder-note {
    font-size: var(--font-s);
    color: #8a5a00;
    background: #fff3cd;
    border: 1px solid #ffe08a;
    border-radius: 8px;
    padding: 0.6rem 0.9rem;
    margin-bottom: 1.25rem;
  }
</style>
