---
interface Props {
  variant?: 'band' | 'card';
}

const { variant = 'band' } = Astro.props as Props;
const isCard = variant === 'card';
---

<section class:list={['newsletter-signup', isCard ? 'newsletter-signup--card' : 'newsletter-signup--band']} data-newsletter-variant={variant}>
  <div class:list={['container', isCard && 'newsletter-signup-container--card']}>
    <div class:list={['newsletter-signup-shell', isCard && 'newsletter-signup-shell--card']}>
      <h2 class="newsletter-signup-title">Подпишитесь на наши новости</h2>
      <p class="newsletter-signup-subtitle">
        {isCard
          ? 'Подпишитесь на наши новости, чтобы не пропускать наши активности и акции'
          : 'Чтобы не пропускать наши активности и акции'}
      </p>

      {isCard ? (
        <form class="newsletter-signup-form newsletter-signup-form--card" action="#" method="post">
          <input
            type="text"
            name="name"
            placeholder="Ваше имя"
            autocomplete="name"
            class="newsletter-signup-input"
          />
          <input
            type="tel"
            name="phone"
            placeholder="Ваш телефон"
            autocomplete="tel"
            class="newsletter-signup-input"
          />
          <input
            type="email"
            name="email"
            placeholder="Ваша почта"
            autocomplete="email"
            class="newsletter-signup-input"
          />
          <label class="newsletter-signup-consent">
            <input type="checkbox" name="consent" required />
            <span>Я согласен с обработкой персональных данных и политикой конфиденциальности</span>
          </label>
          <button type="submit" class="newsletter-signup-button newsletter-signup-button--card">Подписаться</button>
        </form>
      ) : (
        <form class="newsletter-signup-form newsletter-signup-form--band" action="#" method="post">
          <input
            type="email"
            name="email"
            placeholder="Ваш email"
            required
            autocomplete="email"
            class="newsletter-signup-input newsletter-signup-input--band"
          />
          <button type="submit" class="newsletter-signup-button newsletter-signup-button--band">Подписаться</button>
        </form>
      )}
    </div>
  </div>
</section>

<style>
  .newsletter-signup {
    margin-top: 3rem;
  }

  .newsletter-signup--band {
    background: var(--color-accent-900);
    color: var(--color-light-100);
    padding: 3rem 0;
  }

  .newsletter-signup--card {
    padding: 0 0 2.5rem;
  }

  .newsletter-signup-container--card {
    display: flex;
    justify-content: center;
  }

  .newsletter-signup-shell {
    text-align: center;
  }

  .newsletter-signup-shell--card {
    width: min(100%, 28rem);
    padding: 1.9rem 2rem 1.8rem;
    border: 1px solid #e7e7e7;
    border-radius: 20px;
    background: var(--color-light-100);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .newsletter-signup--band .newsletter-signup-shell {
    max-width: 37.5rem;
    margin: 0 auto;
  }

  .newsletter-signup-title {
    margin: 0 0 0.5rem;
    font-size: var(--font-xxl);
    line-height: 1.15;
  }

  .newsletter-signup--band .newsletter-signup-title {
    color: var(--color-light-100);
  }

  .newsletter-signup--card .newsletter-signup-title {
    color: var(--color-dark-700);
    text-align: left;
  }

  .newsletter-signup-subtitle {
    margin: 0 0 1.35rem;
    line-height: 1.5;
  }

  .newsletter-signup--band .newsletter-signup-subtitle {
    color: var(--color-gray-300);
  }

  .newsletter-signup--card .newsletter-signup-subtitle {
    color: var(--color-gray-500);
    text-align: left;
  }

  .newsletter-signup-form {
    display: flex;
  }

  .newsletter-signup-form--band {
    gap: 0.75rem;
    justify-content: center;
  }

  .newsletter-signup-form--card {
    flex-direction: column;
    gap: 0.65rem;
  }

  .newsletter-signup-input {
    width: 100%;
    min-width: 0;
    border-radius: 4px;
    font-size: var(--font-s);
  }

  .newsletter-signup-input--band {
    max-width: 22.5rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-light-100);
  }

  .newsletter-signup-input--band::placeholder {
    color: var(--color-gray-400);
  }

  .newsletter-signup-form--card .newsletter-signup-input {
    height: 2.5rem;
    padding: 0 0.9rem;
    border: 1px solid #d7d7d7;
    background: #fff;
    color: var(--color-dark-700);
  }

  .newsletter-signup-consent {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    color: var(--color-gray-600);
    font-size: 0.68rem;
    line-height: 1.45;
    text-align: left;
  }

  .newsletter-signup-consent input {
    margin-top: 0.15rem;
  }

  .newsletter-signup-button {
    border: 0;
    cursor: pointer;
    font-size: var(--font-s);
    font-weight: 600;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .newsletter-signup-button--band {
    white-space: nowrap;
    padding: 0 1.25rem;
    border-radius: var(--radius-m);
    background: var(--color-accent-600);
    color: var(--color-light-100);
  }

  .newsletter-signup-button--card {
    height: 2.75rem;
    border-radius: 4px;
    background: #4ea847;
    color: #fff;
  }

  @media (max-width: 640px) {
    .newsletter-signup--band {
      padding: 2.25rem 0;
    }

    .newsletter-signup-form--band {
      flex-direction: column;
      align-items: stretch;
    }

    .newsletter-signup-input--band {
      max-width: none;
    }

    .newsletter-signup-shell--card {
      padding: 1.5rem;
    }
  }
</style>
