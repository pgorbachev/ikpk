---
---

<header class="header">
  <div class="header-inner">
    <!-- Mobile menu toggle -->
    <button class="mobile-toggle" id="menu-toggle" aria-label="Открыть меню" aria-expanded="false">
      <span class="hamburger"></span>
    </button>

    <!-- Logo -->
    <a href="/" class="logo" aria-label="ИКПК — Главная">
      <img src="/logo-wordmark.svg" alt="ИКПК" class="logo-wordmark" width="131" height="36" />
    </a>

    <!-- Right section -->
    <div class="header-right">
      <a href="tel:+78126465450" class="header-phone" aria-label="Позвонить: +7 (812) 646-54-50">
        <svg class="phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        <span class="phone-text">+7 (812) 646-54-50</span>
      </a>
      <div class="header-controls" role="toolbar" aria-label="Инструменты шапки">
        <button
          class="header-control header-tool-button"
          id="header-search-toggle"
          type="button"
          aria-label="Открыть поиск"
          aria-expanded="false"
          aria-controls="header-search"
          data-header-tool="search"
        >
          <svg class="control-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"></circle><path d="M20 20L16.65 16.65"></path></svg>
        </button>
        <button
          class="header-control header-tool-button header-control-text"
          type="button"
          aria-label="Открыть меню версии сайта для слабовидящих"
          data-header-tool="vision"
        >
          <span class="visually-control-aa">A<span class="visually-control-aa-small">a</span></span>
        </button>
        <button
          class="header-control header-theme-toggle"
          id="theme-toggle"
          type="button"
          role="switch"
          aria-label="Переключить на темную тему"
          aria-checked="false"
          data-header-tool="theme"
        >
          <span class="theme-toggle-track" aria-hidden="true">
            <span class="theme-toggle-thumb" data-theme-thumb></span>
          </span>
        </button>
      </div>
    </div>
  </div>
  <div class="header-search" id="header-search" hidden>
    <form class="header-search-form" action="/statyi" method="get" role="search">
      <label class="sr-only" for="header-search-input">Поиск по сайту</label>
      <input
        id="header-search-input"
        class="header-search-input"
        type="search"
        name="q"
        placeholder="Поиск по сайту"
        autocomplete="off"
      />
      <button class="header-search-submit" type="submit">Найти</button>
      <button
        class="header-search-close"
        id="header-search-close"
        type="button"
        aria-label="Закрыть поиск"
      >
        ✕
      </button>
    </form>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: var(--color-light-300);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 1.125rem;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover { text-decoration: none; }

  .logo-wordmark {
    height: 28px;
    width: auto;
  }

  .header-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-dark-700);
    text-decoration: none;
    font-size: var(--font-s);
    font-weight: 500;
    white-space: nowrap;
    padding-right: 0.75rem;
    border-right: 1px solid var(--color-gray-150);
  }

  .header-phone:hover {
    color: var(--color-accent-600);
    text-decoration: none;
  }

  .phone-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid #cfd2d5;
    border-radius: 6px;
    background: var(--color-light-100);
    padding: 2px;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.72) inset, 0 1px 1px rgba(18, 20, 18, 0.08);
  }

  .header-control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: var(--color-dark-700);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s, box-shadow 0.15s;
  }

  .header-tool-button {
    width: 32px;
    height: 32px;
    border: 1px solid #d9ddde;
    border-radius: 4px;
    background: linear-gradient(180deg, #ffffff 0%, #f1f3f2 100%);
  }

  .header-control:hover {
    background: #ecefee;
    border-color: #c6cbcc;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.85) inset;
  }

  .header-control:active {
    background: #e3e7e5;
    box-shadow: inset 0 1px 2px rgba(30, 33, 30, 0.18);
  }

  .header-control:focus-visible {
    outline: 2px solid #4a4a4a;
    outline-offset: 1px;
  }

  .header-control-text {
    width: auto;
    min-width: 36px;
    padding: 0 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .control-icon {
    width: 16px;
    height: 16px;
  }

  .visually-control-aa {
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
  }

  .visually-control-aa-small {
    font-size: 0.82em;
  }

  .header-theme-toggle {
    width: 52px;
    height: 32px;
    border: 1px solid #c9ced2;
    border-radius: 999px;
    background: #e7ebef;
    padding: 2px;
    justify-content: flex-start;
  }

  .theme-toggle-track {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  .theme-toggle-thumb {
    position: absolute;
    top: 1px;
    left: 1px;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.22);
    transition: transform 0.18s ease;
  }

  .header-theme-toggle[aria-checked='true'] {
    background: #516552;
    border-color: #455646;
  }

  .header-theme-toggle[aria-checked='true'] .theme-toggle-thumb {
    transform: translateX(22px);
  }

  .header-theme-toggle:hover {
    border-color: #b7bec3;
    background: #dfe4e8;
  }

  .header-theme-toggle[aria-checked='true']:hover {
    background: #4a5d4c;
  }

  .header-control[data-header-tool='search'][aria-expanded='true'] {
    background: #dde7de;
    border-color: #bbcfbe;
    color: #2f5d34;
  }

  .header-search {
    position: absolute;
    right: 1.125rem;
    left: auto;
    top: calc(100% - 1px);
    width: min(560px, calc(100% - 2.25rem));
    z-index: 101;
    border: 1px solid #d1d4d0;
    border-radius: 8px;
    background: #f5f6f3;
    padding: 0.55rem;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.14);
  }

  .header-search-form {
    margin-left: 0;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .header-search-input {
    width: 100%;
    height: 38px;
    border: 1px solid #c9cdca;
    border-radius: 6px;
    background: var(--color-light-100);
    color: var(--color-dark-700);
    padding: 0 0.75rem;
    font-size: var(--font-s);
  }

  .header-search-input:focus {
    outline: 2px solid #4a4a4a;
    outline-offset: 0;
    border-color: #4a4a4a;
  }

  .header-search-submit {
    height: 38px;
    padding: 0 0.95rem;
    border: 1px solid #c4c9c5;
    border-radius: 6px;
    background: #ecefea;
    color: var(--color-dark-700);
    font-size: var(--font-s);
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .header-search-submit:hover {
    background: #e5e9e4;
  }

  .header-search-close {
    width: 34px;
    height: 34px;
    border: 0;
    background: transparent;
    color: var(--color-gray-600);
    cursor: pointer;
  }

  .header-search-close:hover {
    color: var(--color-dark-700);
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-shrink: 0;
  }

  .hamburger {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark-700);
    position: relative;
    transition: background 0.2s;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 2px;
    background: var(--color-dark-700);
    left: 0;
    transition: transform 0.2s;
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  @media (max-width: 1024px) {
    .mobile-toggle { display: block; }
    .phone-text { display: none; }
    .phone-icon { width: 22px; height: 22px; }
    .header-phone { border-right: 0; padding-right: 0; }
    .header-control-text { display: none; }
    .header-theme-toggle {
      width: 44px;
    }
    .header-theme-toggle[aria-checked='true'] .theme-toggle-thumb {
      transform: translateX(16px);
    }
    .header-search {
      left: 0;
      right: 0;
      width: 100%;
      border-radius: 0;
      border-left: 0;
      border-right: 0;
      padding: 0.5rem 0.75rem;
    }

    .header-search-form {
      width: 100%;
    }

    .header-search-submit {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .logo-wordmark {
      height: 24px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const themeToggle = document.getElementById('theme-toggle');
  const searchToggle = document.getElementById('header-search-toggle');
  const searchPanel = document.getElementById('header-search') as HTMLElement | null;
  const searchInput = document.getElementById('header-search-input') as HTMLInputElement | null;
  const searchClose = document.getElementById('header-search-close');

  toggle?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.toggle('open');
    overlay?.classList.toggle('visible', isOpen);
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });

  const closeSearch = () => {
    if (!searchPanel || !searchToggle) return;
    searchPanel.hidden = true;
    searchToggle.setAttribute('aria-expanded', 'false');
  };

  const openSearch = () => {
    if (!searchPanel || !searchToggle || !searchInput) return;
    searchPanel.hidden = false;
    searchToggle.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => {
      searchInput.focus();
      searchInput.select();
    });
  };

  searchToggle?.addEventListener('click', () => {
    const expanded = searchToggle.getAttribute('aria-expanded') === 'true';
    if (expanded) {
      closeSearch();
    } else {
      openSearch();
    }
  });

  searchClose?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeSearch();
    }
  });

  document.addEventListener('click', (event) => {
    if (!searchPanel || searchPanel.hidden) return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (
      searchPanel.contains(target) ||
      searchToggle?.contains(target)
    ) {
      return;
    }
    closeSearch();
  });

  const resolveTheme = (value: string) => value === 'dark' ? 'dark' : 'light';

  const applyTheme = (theme: string) => {
    const normalized = resolveTheme(theme);
    document.documentElement.dataset.theme = normalized;
    if (!themeToggle) return;
    const isDark = normalized === 'dark';
    themeToggle.setAttribute('aria-checked', String(isDark));
    themeToggle.setAttribute('aria-label', isDark ? 'Переключить на светлую тему' : 'Переключить на темную тему');
  };

  const savedTheme = resolveTheme(localStorage.getItem('ikpk.theme') || document.documentElement.dataset.theme || 'light');
  applyTheme(savedTheme);

  themeToggle?.addEventListener('click', () => {
    const currentTheme = resolveTheme(document.documentElement.dataset.theme || 'light');
    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
    applyTheme(nextTheme);
    localStorage.setItem('ikpk.theme', nextTheme);
  });
</script>
