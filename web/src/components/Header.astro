---
---

<header class="header">
  <div class="header-inner">
    <!-- Mobile menu toggle -->
    <button class="mobile-toggle" id="menu-toggle" aria-label="Открыть меню" aria-expanded="false">
      <span class="hamburger"></span>
    </button>

    <!-- Logo -->
    <a href="/" class="logo" aria-label="ИКПК — Главная">
      <img src="/logo-wordmark.svg" alt="ИКПК" class="logo-wordmark" width="131" height="36" />
    </a>

    <!-- Right section: phone -->
    <div class="header-right">
      <a href="tel:+78126465450" class="header-phone">
        <svg class="phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        <span class="phone-text">+7 (812) 646-54-50</span>
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: var(--color-light-100);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 1rem;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover { text-decoration: none; }

  .logo-wordmark {
    height: 28px;
    width: auto;
  }

  .header-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header-phone {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-dark-700);
    text-decoration: none;
    font-size: var(--font-s);
    font-weight: 500;
    white-space: nowrap;
  }

  .header-phone:hover {
    color: var(--color-accent-600);
    text-decoration: none;
  }

  .phone-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-shrink: 0;
  }

  .hamburger {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark-700);
    position: relative;
    transition: background 0.2s;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 2px;
    background: var(--color-dark-700);
    left: 0;
    transition: transform 0.2s;
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  @media (max-width: 1024px) {
    .mobile-toggle { display: block; }
    .phone-text { display: none; }
    .phone-icon { width: 22px; height: 22px; }
  }

  @media (max-width: 480px) {
    .logo-wordmark {
      height: 24px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  toggle?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.toggle('open');
    overlay?.classList.toggle('visible', isOpen);
    toggle.setAttribute('aria-expanded', String(!!isOpen));
  });
</script>
