---
import type { Seminar } from '../lib/data';
import { excerpt } from '../lib/data';
import MediaCard from './ui/MediaCard.astro';

interface Props {
  seminar: Seminar;
  href: string;
}

const { seminar, href } = Astro.props;
const statusLabel: Record<string, string> = {
  active: 'Набор открыт',
  not_planned: 'Не запланирован',
  completed: 'Завершён',
};
---

<MediaCard
  href={href}
  title={seminar.name}
  className="seminar-card"
  titleClassName="seminar-card-title"
>
  {seminar.status && (
    <span slot="eyebrow" class:list={['badge', `badge-${seminar.status}`]}>
      {statusLabel[seminar.status] || seminar.status}
    </span>
  )}
  {seminar.description_text && (
    <p class="seminar-card-excerpt">{excerpt(seminar.description_text, 150)}</p>
  )}
</MediaCard>

<style>
  :global(.seminar-card .seminar-card-title) {
    margin-bottom: 0.5rem;
  }

  .seminar-card-excerpt {
    font-size: var(--font-s);
    color: var(--color-gray-600);
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  :global(.seminar-card .badge) {
    font-size: var(--font-xs);
    margin-bottom: 0.5rem;
  }
</style>
