---
interface Props {
  title: string;
  titleHref: string;
  imageUrl?: string;
  imageAlt?: string;
  teacherLabel: string;
  teacherName: string;
  teacherHref?: string;
  instituteName: string;
  programName: string;
  dateLabel: string;
  cityName: string;
  priceLabel: string;
  registrationHref?: string;
  additionalText?: string;
  extraNote?: string;
}

const {
  title,
  titleHref,
  imageUrl = '',
  imageAlt = '',
  teacherLabel,
  teacherName,
  teacherHref = '',
  instituteName,
  programName,
  dateLabel,
  cityName,
  priceLabel,
  registrationHref = '',
  additionalText = '',
  extraNote = '',
} = Astro.props as Props;

const isTimeNote = additionalText.trim().toLowerCase().startsWith('начало');
const isStatusNote = !isTimeNote && Boolean(additionalText);
const isFreePrice = priceLabel.trim().toLowerCase() === 'бесплатно';
---

<article class="schedule-card" data-testid="schedule-card">
  <div class="schedule-card-media">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={imageAlt || `Изображение для события «${title}»`}
        loading="lazy"
        width="420"
        height="280"
        data-testid="schedule-card-image"
      />
    ) : (
      <div class="schedule-card-fallback" data-testid="schedule-card-image">
        <span class="schedule-card-fallback-label">Расписание ИКПК</span>
        <span class="schedule-card-fallback-title">{title}</span>
      </div>
    )}
  </div>

  <div class="schedule-card-body">
    {additionalText && (
      <p class:list={['schedule-card-note', isTimeNote && 'schedule-card-note--time', isStatusNote && 'schedule-card-note--status']}>
        {additionalText}
      </p>
    )}
    {extraNote && <p class="schedule-card-note schedule-card-note--subtle">{extraNote}</p>}

    <h3 class="schedule-card-title" data-testid="schedule-card-title">
      <a href={titleHref}>{title}</a>
    </h3>

    <dl class="schedule-card-details">
      <div class="schedule-card-detail">
        <dt>{teacherLabel}</dt>
        <dd>
          {teacherHref ? <a href={teacherHref}>{teacherName}</a> : teacherName}
        </dd>
      </div>
      <div class="schedule-card-detail">
        <dt>Институт:</dt>
        <dd>{instituteName}</dd>
      </div>
      <div class="schedule-card-detail">
        <dt>Программа обучения:</dt>
        <dd data-testid="schedule-card-program">{programName}</dd>
      </div>
      <div class="schedule-card-detail">
        <dt>Дата проведения:</dt>
        <dd>{dateLabel}</dd>
      </div>
      <div class="schedule-card-detail">
        <dt>Место проведения:</dt>
        <dd data-testid="schedule-card-city">{cityName}</dd>
      </div>
    </dl>

    <div class="schedule-card-footer">
      <div class:list={['schedule-card-price', isFreePrice && 'schedule-card-price--free']}>{priceLabel}</div>
      <div class="schedule-card-actions">
        <a href={titleHref} class="btn btn-outline">Подробнее</a>
        {registrationHref && (
          <a href={registrationHref} class="btn btn-primary" target="_blank" rel="noopener">
            Зарегистрироваться
          </a>
        )}
      </div>
    </div>
  </div>
</article>

<style>
  .schedule-card {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 1rem;
    border: 1px solid #deded7;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.16);
    overflow: hidden;
    transition: box-shadow 180ms ease, transform 180ms ease, border-color 180ms ease;
  }

  .schedule-card:hover {
    border-color: #d1d1c8;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.18);
    transform: translateY(-1px);
  }

  .schedule-card-media {
    min-height: 100%;
    background: #f3f3ef;
  }

  .schedule-card-media img,
  .schedule-card-fallback {
    display: block;
    width: 100%;
    height: 240px;
    min-height: 240px;
  }

  .schedule-card-media img {
    object-fit: cover;
  }

  .schedule-card-fallback {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.55rem;
    padding: 1.1rem;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.75) 0%, rgba(255, 255, 255, 0) 34%),
      linear-gradient(135deg, #f4f4f1 0%, #e6e6e0 100%);
  }

  .schedule-card-fallback-label {
    font-size: var(--font-xs);
    color: var(--color-gray-500);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .schedule-card-fallback-title {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-dark-700);
  }

  .schedule-card-body {
    padding: 0.9rem 1rem 0.95rem 0;
  }

  .schedule-card-note {
    margin: 0 0 0.45rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-dark-700);
  }

  .schedule-card-note--time {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 1.5rem;
    padding: 0 1rem;
    border-radius: 999px;
    background: rgb(237, 198, 119);
    color: #1f1f1b;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5rem;
  }

  .schedule-card-note--status {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding: 0.15rem 0.75rem;
    border-radius: 999px;
    background: rgba(46, 125, 50, 0.1);
    color: #2e6e32;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .schedule-card-note--subtle {
    color: #7b3f00;
  }

  .schedule-card-title {
    margin: 0 0 0.7rem;
    font-size: 1rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .schedule-card-title a {
    color: inherit;
    text-decoration: none;
  }

  .schedule-card-title a:hover {
    text-decoration: underline;
  }

  .schedule-card-details {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem 0.9rem;
  }

  .schedule-card-detail {
    margin: 0;
  }

  .schedule-card-detail dt {
    margin: 0 0 0.14rem;
    font-size: var(--font-xs);
    color: var(--color-gray-500);
  }

  .schedule-card-detail dd {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-dark-700);
  }

  .schedule-card-detail a {
    color: inherit;
  }

  .schedule-card-footer {
    margin-top: 0.85rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .schedule-card-price {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0 0.75rem;
    border-radius: 28px;
    background: rgb(230, 242, 230);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 2.25rem;
    color: rgb(26, 26, 26);
    white-space: nowrap;
  }

  .schedule-card-price--free {
    background: rgb(230, 242, 230);
    color: rgb(26, 26, 26);
  }

  .schedule-card-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  @media (max-width: 900px) {
    .schedule-card {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .schedule-card-body {
      padding: 1.1rem 1.1rem 1.2rem;
    }

    .schedule-card-details {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .schedule-card-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .schedule-card-actions {
      width: 100%;
      justify-content: stretch;
    }

    .schedule-card-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }

  :root[data-theme='dark'] .schedule-card {
    border-color: #434a43;
    background: #232723;
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.34);
  }

  :root[data-theme='dark'] .schedule-card:hover {
    border-color: #5a635a;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.42);
  }

  :root[data-theme='dark'] .schedule-card-media {
    background: #2d322d;
  }

  :root[data-theme='dark'] .schedule-card-fallback {
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0) 32%),
      linear-gradient(135deg, #2c312c 0%, #1f241f 100%);
  }

  :root[data-theme='dark'] .schedule-card-note--time {
    background: #d5ae58;
    color: #171712;
  }

  :root[data-theme='dark'] .schedule-card-note--status {
    background: rgba(124, 201, 132, 0.14);
    color: #9fd5a3;
  }

  :root[data-theme='dark'] .schedule-card-price {
    background: #314836;
    color: #f2f5f1;
  }

  :root[data-theme='dark'] .schedule-card-price--free {
    background: #314836;
    color: #f2f5f1;
  }
  
</style>
