---
interface Option {
  label: string;
  value: string;
}

interface ProgramOption {
  instituteSlug: string;
  name: string;
  slug: string;
}

interface Props {
  institutes: Option[];
  programs: ProgramOption[];
  cities: string[];
}

const { institutes, programs, cities } = Astro.props as Props;
---

<div class="schedule-toolbar" data-testid="schedule-toolbar">
  <label class="schedule-field">
    <span class="schedule-field-label schedule-field-label--sr">Поиск</span>
    <input
      type="search"
      placeholder="Поиск..."
      class="schedule-search"
      data-testid="schedule-search"
      data-schedule-search
    />
  </label>

  <label class="schedule-field">
    <span class="schedule-field-label">Институт</span>
    <select class="schedule-select" data-testid="schedule-filter-institute" data-schedule-filter="institute">
      <option value="">Не выбрано</option>
      {institutes.map((institute) => (
        <option value={institute.value}>{institute.label}</option>
      ))}
    </select>
  </label>

  <label class="schedule-field">
    <span class="schedule-field-label">Программа обучения</span>
    <select class="schedule-select" data-testid="schedule-filter-program" data-schedule-filter="program" disabled>
      <option value="">Не выбрано</option>
      {programs.map((program) => (
        <option value={program.slug} data-institute={program.instituteSlug}>{program.name}</option>
      ))}
    </select>
  </label>

  <label class="schedule-field">
    <span class="schedule-field-label">Место проведения</span>
    <select class="schedule-select" data-testid="schedule-filter-city" data-schedule-filter="city">
      <option value="">Не выбрано</option>
      {cities.map((city) => (
        <option value={city.toLowerCase().replace(/ё/g, 'е').replace(/[^a-zа-я0-9]+/gi, '-').replace(/^-+|-+$/g, '')}>{city}</option>
      ))}
    </select>
  </label>
</div>

<style>
  .schedule-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(180px, 1fr));
    gap: 0.75rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .schedule-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .schedule-field-label {
    font-size: var(--font-xs);
    color: var(--color-gray-500);
  }

  .schedule-field-label--sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .schedule-search,
  .schedule-select {
    width: 100%;
    min-height: 36px;
    padding: 0.45rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #bdbdbd;
    background: #fff;
    color: var(--color-dark-700);
    font: inherit;
    font-size: 0.95rem;
  }

  .schedule-select:disabled {
    color: var(--color-gray-500);
    background: #f6f6f4;
  }

  .schedule-select {
    appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, #6b6b66 50%),
      linear-gradient(135deg, #6b6b66 50%, transparent 50%);
    background-position:
      calc(100% - 16px) calc(50% - 2px),
      calc(100% - 11px) calc(50% - 2px);
    background-size: 5px 5px, 5px 5px;
    background-repeat: no-repeat;
    padding-right: 2rem;
  }

  @media (max-width: 1100px) {
    .schedule-toolbar {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .schedule-toolbar {
      grid-template-columns: 1fr;
    }
  }

  :root[data-theme='dark'] .schedule-field-label {
    color: #b2bbb2;
  }

  :root[data-theme='dark'] .schedule-search,
  :root[data-theme='dark'] .schedule-select {
    border-color: #556055;
    background: #232723;
    color: #edf1ec;
  }

  :root[data-theme='dark'] .schedule-select:disabled {
    background: #1d201d;
    color: #8e978e;
  }
</style>
