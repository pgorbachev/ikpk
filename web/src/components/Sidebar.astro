---
import { getInstitutes } from '../lib/data';
const institutes = getInstitutes();
const pathname = Astro.url.pathname;

function isActive(path: string): boolean {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
}
---

<aside class="sidebar" id="sidebar">
  <nav class="sidebar-menu" aria-label="Основная навигация">
    <!-- Top items -->
    <ul class="menu-list">
      <li class="menu-item">
        <a href="/" class:list={['menu-link', { active: isActive('/') && pathname === '/' }]}>
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h3a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1h3a1 1 0 001-1V10" /></svg>
          <span class="menu-label">Главная</span>
        </a>
      </li>
      <li class="menu-item">
        <a href="/aktsii-i-skidki" class:list={['menu-link', { active: isActive('/aktsii-i-skidki') }]}>
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="menu-label">Акции и скидки</span>
        </a>
      </li>
      <li class="menu-item">
        <a href="https://kinezio.shop/" class="menu-link" target="_blank" rel="noopener noreferrer">
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" /></svg>
          <span class="menu-label">Магазин</span>
          <svg class="ext-icon" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 1.5h7v7M10 2L2 10" /></svg>
        </a>
      </li>
    </ul>

    <!-- Образование -->
    <div class="menu-section">
      <button class="section-toggle" type="button" aria-expanded="true" aria-controls="section-education" data-section="education">
        <span class="section-title">Образование</span>
        <svg class="section-arrow" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>
      </button>
      <ul class="menu-list section-items" id="section-education">
        {institutes.map((inst) => (
          <li class="menu-item">
            <a href={`/${inst.slug}`} class:list={['menu-link', { active: isActive(`/${inst.slug}`) }]}>
              <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
              <span class="menu-label">{inst.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Standalone items -->
    <ul class="menu-list">
      <li class="menu-item">
        <a href="/raspisanie-i-tseny" class:list={['menu-link', { active: isActive('/raspisanie-i-tseny') }]}>
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          <span class="menu-label">Расписание и цены</span>
        </a>
      </li>
      <li class="menu-item">
        <a href="/oplata" class:list={['menu-link', { active: isActive('/oplata') }]}>
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
          <span class="menu-label">Оплата</span>
        </a>
      </li>
    </ul>

    <!-- Публикации -->
    <div class="menu-section">
      <button class="section-toggle" type="button" aria-expanded="true" aria-controls="section-publications" data-section="publications">
        <span class="section-title">Публикации</span>
        <svg class="section-arrow" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>
      </button>
      <ul class="menu-list section-items" id="section-publications">
        <li class="menu-item">
          <a href="/statyi" class:list={['menu-link', { active: isActive('/statyi') }]}>
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2" /></svg>
            <span class="menu-label">Статьи</span>
          </a>
        </li>
        <li class="menu-item">
          <a href="/video" class:list={['menu-link', { active: isActive('/video') }]}>
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            <span class="menu-label">Видео</span>
          </a>
        </li>
        <li class="menu-item">
          {/* nofollow: не передаём SEO-вес Яндекс.Диску (domain_strategy.md) */}
          <a href="https://disk.yandex.ru/d/8Xr5NSBO0wFUkQ" class="menu-link" target="_blank" rel="nofollow noopener noreferrer">
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            <span class="menu-label">Фото</span>
            <svg class="ext-icon" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 1.5h7v7M10 2L2 10" /></svg>
          </a>
        </li>
      </ul>
    </div>

    <!-- Информация -->
    <div class="menu-section">
      <button class="section-toggle" type="button" aria-expanded="true" aria-controls="section-information" data-section="information">
        <span class="section-title">Информация</span>
        <svg class="section-arrow" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" /></svg>
      </button>
      <ul class="menu-list section-items" id="section-information">
        <li class="menu-item">
          <a href="/svedeniya-ob-obrazovatelnoy-organizatsii" class:list={['menu-link', { active: isActive('/svedeniya-ob-obrazovatelnoy-organizatsii') }]}>
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            <span class="menu-label">Сведения об образовательной организации</span>
          </a>
        </li>
        <li class="menu-item">
          <a href="/sotrudnichestvo-s-nami" class:list={['menu-link', { active: isActive('/sotrudnichestvo-s-nami') }]}>
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span class="menu-label">Сотрудничество с нами</span>
          </a>
        </li>
        <li class="menu-item">
          <a href="https://mudriydoctor.ru/" class="menu-link" target="_blank" rel="noopener noreferrer">
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
            <span class="menu-label">Медицинский центр</span>
            <svg class="ext-icon" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3.5 1.5h7v7M10 2L2 10" /></svg>
          </a>
        </li>
        <li class="menu-item">
          <a href="/kontakty" class:list={['menu-link', { active: isActive('/kontakty') }]}>
            <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span class="menu-label">Контакты</span>
          </a>
        </li>
      </ul>
    </div>
  </nav>
</aside>

<!-- Sidebar overlay for mobile -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<style>
  .sidebar {
    position: fixed;
    top: var(--header-height);
    left: 0;
    bottom: 0;
    width: var(--sidebar-width);
    background: var(--color-light-300);
    border-right: 1px solid var(--color-gray-200);
    overflow-y: auto;
    z-index: 90;
    padding: 0;
    scrollbar-width: thin;
  }

  .sidebar::-webkit-scrollbar {
    width: 4px;
  }
  .sidebar::-webkit-scrollbar-thumb {
    background: var(--color-gray-200);
    border-radius: 2px;
  }

  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 89;
  }

  .menu-list {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .menu-item {
    margin: 0;
  }

  .menu-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 48px;
    padding: 0 1rem;
    font-size: 0.875rem;
    color: var(--color-gray-600);
    text-decoration: none;
    border-radius: 0;
    border: 0;
    border-left: 3px solid transparent;
    background: transparent;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1.4;
  }

  .menu-link:hover {
    background: var(--color-gray-150);
    color: var(--color-dark-700);
    text-decoration: none;
  }

  .menu-link:active {
    background: var(--color-gray-200);
  }

  .menu-link.active {
    background: var(--color-accent-50);
    color: var(--color-dark-700);
    border-left-color: var(--color-accent-500);
    font-weight: 500;
  }

  .menu-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    opacity: 0.68;
    color: var(--color-gray-500);
    transition: color 0.15s, opacity 0.15s;
  }

  .menu-link:hover .menu-icon {
    opacity: 0.85;
    color: var(--color-gray-600);
  }

  .menu-link.active .menu-icon {
    opacity: 0.75;
    color: currentColor;
  }

  .menu-label {
    flex: 1;
  }

  .ext-icon {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    opacity: 0.4;
  }

  .menu-section {
    margin-top: 0;
    padding: 0;
    border-top: 1px solid var(--color-gray-200);
  }

  .section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    min-height: 48px;
    padding: 0 0.75rem;
    background: transparent;
    border: none;
    border-radius: 0;
    cursor: pointer;
    color: var(--color-gray-600);
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0;
    transition: background-color 0.15s, color 0.15s;
  }

  .section-toggle:hover {
    background: var(--color-gray-150);
    color: var(--color-dark-700);
  }

  .section-toggle:active {
    background: var(--color-gray-200);
  }

  .section-title {
    line-height: 1.25;
  }

  .section-arrow {
    width: 14px;
    height: 14px;
    color: currentColor;
    opacity: 0.6;
    transition: transform 0.2s;
  }

  .section-toggle[aria-expanded="false"] .section-arrow {
    transform: rotate(-90deg);
  }

  .section-toggle[aria-expanded="false"] + .section-items {
    display: none;
  }

  .section-items {
    padding: 0;
  }

  .section-items .menu-link {
    padding: 0 0.75rem;
  }

  .section-items .menu-icon {
    display: none;
  }

  @media (max-width: 1024px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      width: 280px;
      box-shadow: none;
    }

    .sidebar.open {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);
    }

    .sidebar-overlay.visible {
      display: block;
    }
  }
</style>

<script>
  // Section toggle with persisted state
  document.querySelectorAll('.section-toggle').forEach((btn) => {
    const section = btn.getAttribute('data-section');
    const key = section ? `ikpk.sidebar.${section}` : null;
    if (key) {
      try {
        const saved = localStorage.getItem(key);
        if (saved === 'collapsed') {
          btn.setAttribute('aria-expanded', 'false');
        }
      } catch {
        // Ignore storage access failures in private browsing and locked-down clients.
      }
    }
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const next = String(!expanded);
      btn.setAttribute('aria-expanded', next);
      if (key) {
        try {
          localStorage.setItem(key, next === 'true' ? 'expanded' : 'collapsed');
        } catch {
          // Ignore storage access failures in private browsing and locked-down clients.
        }
      }
    });
  });

  // Close sidebar on overlay click (mobile)
  const overlay = document.getElementById('sidebar-overlay');
  const sidebar = document.getElementById('sidebar');
  overlay?.addEventListener('click', () => {
    sidebar?.classList.remove('open');
    overlay?.classList.remove('visible');
    document.querySelector('.mobile-toggle')?.setAttribute('aria-expanded', 'false');
  });
</script>
