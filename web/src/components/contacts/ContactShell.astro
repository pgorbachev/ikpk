---
interface Props {
  address: string;
  addressLabel: string;
  hours: string;
  institutePhone: string;
  email: string;
  storeUrl: string;
  clinicPhone: string;
  clinicUrl: string;
  requisites: string[];
  mapSrc: string;
  mapOpenUrl?: string;
}

const {
  address,
  addressLabel,
  hours,
  institutePhone,
  email,
  storeUrl,
  clinicPhone,
  clinicUrl,
  requisites,
  mapSrc,
  mapOpenUrl,
} = Astro.props as Props;
---

<section class="contact-shell" aria-label="Контактная информация">
  <address class="contact-shell-info">
    <div class="contact-shell-section">
      <div class="contact-shell-item">
        <span class="contact-shell-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M12 12C10.9 12 10 11.1 10 10C10 8.9 10.9 8 12 8C13.1 8 14 8.9 14 10C14 11.1 13.1 12 12 12ZM18 10.2C18 6.57 15.35 4 12 4C8.65 4 6 6.57 6 10.2C6 12.54 7.95 15.64 12 19.34C16.05 15.64 18 12.54 18 10.2ZM12 2C16.2 2 20 5.22 20 10.2C20 13.52 17.33 17.45 12 22C6.67 17.45 4 13.52 4 10.2C4 5.22 7.8 2 12 2Z" fill="currentColor"></path></svg>
        </span>
        <div class="contact-shell-text">
          <span class="contact-shell-strong">{addressLabel}</span>, {address}
        </div>
      </div>
      <div class="contact-shell-item">
        <span class="contact-shell-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M11.99 2C6.47 2 2 6.48 2 12C2 17.52 6.47 22 11.99 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 11.99 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20ZM12.5 7.75C12.5 7.33579 12.1642 7 11.75 7C11.3358 7 11 7.33579 11 7.75V12.4338C11 12.7851 11.1843 13.1106 11.4855 13.2913L15.6383 15.783C15.9768 15.9861 16.4159 15.878 16.6214 15.5409C16.8298 15.1992 16.7188 14.7531 16.3746 14.5489L12.5 12.25V7.75Z" fill="currentColor"></path></svg>
        </span>
        <div class="contact-shell-text" set:html={hours} />
      </div>
      <div class="contact-shell-item">
        <span class="contact-shell-icon contact-shell-icon--accent" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M15 12h2c0-2.76-2.24-5-5-5v2c1.66 0 3 1.34 3 3Zm4 0h2a9 9 0 0 0-9-9v2c3.87 0 7 3.13 7 7Zm1 3.5c-1.25 0-2.45-.2-3.57-.57-.1-.03-.21-.05-.31-.05-.26 0-.51.1-.71.29l-2.2 2.2a15.045 15.045 0 0 1-6.59-6.59l2.2-2.21a.96.96 0 0 0 .25-1A11.36 11.36 0 0 1 8.5 4c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1 0 9.39 7.61 17 17 17 .55 0 1-.45 1-1v-3.5c0-.55-.45-1-1-1ZM5.03 5h1.5c.07.88.22 1.75.45 2.58l-1.2 1.21c-.4-1.21-.66-2.47-.75-3.79ZM19 18.97c-1.32-.09-2.6-.35-3.8-.76l1.2-1.2c.85.24 1.72.39 2.6.45v1.51Z" fill="currentColor"></path></svg>
        </span>
        <a class="contact-shell-link" href={`tel:${institutePhone.replace(/[^\d+]/g, '')}`}>{institutePhone}</a>
      </div>
      <div class="contact-shell-item">
        <span class="contact-shell-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M22 6C22 4.9 21.1 4 20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6ZM20 6L12 11L4 6H20ZM20 18H4V8L11.47 12.6688C11.7943 12.8714 12.2057 12.8714 12.53 12.6688L20 8V18Z" fill="currentColor"></path></svg>
        </span>
        <a class="contact-shell-link" href={`mailto:${email}`}>{email}</a>
      </div>
    </div>

    <div class="contact-shell-section">
      <p class="contact-shell-subtitle">Медицинская литература</p>
      <div class="contact-shell-item">
        <span class="contact-shell-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M11.991 3C7.023 3 3 7.032 3 12C3 16.968 7.023 21 11.991 21C16.968 21 21 16.968 21 12C21 7.032 16.968 3 11.991 3ZM18.228 8.4H15.573C15.285 7.275 14.871 6.195 14.331 5.196C15.987 5.763 17.364 6.915 18.228 8.4ZM12 4.836C12.747 5.916 13.332 7.113 13.719 8.4H10.281C10.668 7.113 11.253 5.916 12 4.836ZM5.034 13.8C4.89 13.224 4.8 12.621 4.8 12C4.8 11.379 4.89 10.776 5.034 10.2H8.076C8.004 10.794 7.95 11.388 7.95 12C7.95 12.612 8.004 13.206 8.076 13.8H5.034ZM5.772 15.6H8.427C8.715 16.725 9.129 17.805 9.669 18.804C8.013 18.237 6.636 17.094 5.772 15.6ZM8.427 8.4H5.772C6.636 6.906 8.013 5.763 9.669 5.196C9.129 6.195 8.715 7.275 8.427 8.4ZM12 19.164C11.253 18.084 10.668 16.887 10.281 15.6H13.719C13.332 16.887 12.747 18.084 12 19.164ZM14.106 13.8H9.894C9.813 13.206 9.75 12.612 9.75 12C9.75 11.388 9.813 10.785 9.894 10.2H14.106C14.187 10.785 14.25 11.388 14.25 12C14.25 12.612 14.187 13.206 14.106 13.8ZM14.331 18.804C14.871 17.805 15.285 16.725 15.573 15.6H18.228C17.364 17.085 15.987 18.237 14.331 18.804ZM15.924 13.8C15.996 13.206 16.05 12.612 16.05 12C16.05 11.388 15.996 10.794 15.924 10.2H18.966C19.11 10.776 19.2 11.379 19.2 12C19.2 12.621 19.11 13.224 18.966 13.8H15.924Z" fill="currentColor"></path></svg>
        </span>
        <a class="contact-shell-link" href={storeUrl} target="_blank" rel="noopener">{storeUrl}</a>
      </div>
    </div>

    <div class="contact-shell-section">
      <p class="contact-shell-subtitle">Медицинский центр</p>
      <div class="contact-shell-item">
        <span class="contact-shell-icon contact-shell-icon--accent" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M15 12h2c0-2.76-2.24-5-5-5v2c1.66 0 3 1.34 3 3Zm4 0h2a9 9 0 0 0-9-9v2c3.87 0 7 3.13 7 7Zm1 3.5c-1.25 0-2.45-.2-3.57-.57-.1-.03-.21-.05-.31-.05-.26 0-.51.1-.71.29l-2.2 2.2a15.045 15.045 0 0 1-6.59-6.59l2.2-2.21a.96.96 0 0 0 .25-1A11.36 11.36 0 0 1 8.5 4c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1 0 9.39 7.61 17 17 17 .55 0 1-.45 1-1v-3.5c0-.55-.45-1-1-1ZM5.03 5h1.5c.07.88.22 1.75.45 2.58l-1.2 1.21c-.4-1.21-.66-2.47-.75-3.79ZM19 18.97c-1.32-.09-2.6-.35-3.8-.76l1.2-1.2c.85.24 1.72.39 2.6.45v1.51Z" fill="currentColor"></path></svg>
        </span>
        <a class="contact-shell-link" href={`tel:${clinicPhone.replace(/[^\d+]/g, '')}`}>{clinicPhone}</a>
      </div>
      <div class="contact-shell-item">
        <span class="contact-shell-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none"><path d="M11.991 3C7.023 3 3 7.032 3 12C3 16.968 7.023 21 11.991 21C16.968 21 21 16.968 21 12C21 7.032 16.968 3 11.991 3ZM18.228 8.4H15.573C15.285 7.275 14.871 6.195 14.331 5.196C15.987 5.763 17.364 6.915 18.228 8.4ZM12 4.836C12.747 5.916 13.332 7.113 13.719 8.4H10.281C10.668 7.113 11.253 5.916 12 4.836ZM5.034 13.8C4.89 13.224 4.8 12.621 4.8 12C4.8 11.379 4.89 10.776 5.034 10.2H8.076C8.004 10.794 7.95 11.388 7.95 12C7.95 12.612 8.004 13.206 8.076 13.8H5.034ZM5.772 15.6H8.427C8.715 16.725 9.129 17.805 9.669 18.804C8.013 18.237 6.636 17.094 5.772 15.6ZM8.427 8.4H5.772C6.636 6.906 8.013 5.763 9.669 5.196C9.129 6.195 8.715 7.275 8.427 8.4ZM12 19.164C11.253 18.084 10.668 16.887 10.281 15.6H13.719C13.332 16.887 12.747 18.084 12 19.164ZM14.106 13.8H9.894C9.813 13.206 9.75 12.612 9.75 12C9.75 11.388 9.813 10.785 9.894 10.2H14.106C14.187 10.785 14.25 11.388 14.25 12C14.25 12.612 14.187 13.206 14.106 13.8ZM14.331 18.804C14.871 17.805 15.285 16.725 15.573 15.6H18.228C17.364 17.085 15.987 18.237 14.331 18.804ZM15.924 13.8C15.996 13.206 16.05 12.612 16.05 12C16.05 11.388 15.996 10.794 15.924 10.2H18.966C19.11 10.776 19.2 11.379 19.2 12C19.2 12.621 19.11 13.224 18.966 13.8H15.924Z" fill="currentColor"></path></svg>
        </span>
        <a class="contact-shell-link" href={clinicUrl} target="_blank" rel="noopener">{clinicUrl}</a>
      </div>
    </div>

    <div class="contact-shell-section">
      <p class="contact-shell-subtitle">Наши реквизиты</p>
      <div class="contact-shell-requisites">
        {requisites.map((line) => (
          <p>{line}</p>
        ))}
      </div>
    </div>
  </address>

  <div class="contact-shell-map">
    <iframe
      src={mapSrc}
      title="Карта ИКПК"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
    {mapOpenUrl && (
      <a class="contact-shell-map-link" href={mapOpenUrl} target="_blank" rel="noopener">
        Открыть карту в отдельном окне
      </a>
    )}
  </div>
</section>

<style>
  .contact-shell {
    display: grid;
    grid-template-columns: minmax(0, 38%) minmax(0, 62%);
    min-height: 45rem;
    background: var(--color-light-100);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.16);
  }

  .contact-shell-info {
    margin: 0;
    padding: 1.45rem 1.5rem 1.65rem;
    font-style: normal;
  }

  .contact-shell-section + .contact-shell-section {
    margin-top: 1.5rem;
  }

  .contact-shell-item {
    display: grid;
    grid-template-columns: 1.125rem minmax(0, 1fr);
    align-items: start;
    gap: 0.95rem;
  }

  .contact-shell-item + .contact-shell-item {
    margin-top: 0.8rem;
  }

  .contact-shell-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    color: var(--color-gray-500);
    margin-top: 0.15rem;
  }

  .contact-shell-icon svg {
    width: 100%;
    height: 100%;
  }

  .contact-shell-icon--accent {
    color: var(--color-accent-500);
  }

  .contact-shell-text,
  .contact-shell-link {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-dark-700);
    text-decoration: none;
    word-break: break-word;
  }

  .contact-shell-link:hover {
    color: var(--color-accent-600);
    text-decoration: none;
  }

  .contact-shell-strong {
    font-weight: 700;
  }

  .contact-shell-subtitle {
    margin: 0 0 0.75rem;
    font-size: 0.96rem;
    font-weight: 600;
    color: var(--color-dark-700);
  }

  .contact-shell-requisites p {
    margin: 0;
    font-size: var(--font-s);
    line-height: 1.6;
    color: var(--color-gray-600);
  }

  .contact-shell-map {
    min-height: 100%;
    background: var(--color-light-300);
    display: flex;
    flex-direction: column;
  }

  .contact-shell-map iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 26rem;
    border: 0;
    flex: 1;
  }

  .contact-shell-map-link {
    display: block;
    padding: 0.75rem 0.9rem;
    text-align: center;
    font-size: var(--font-s);
    color: var(--color-dark-700);
    text-decoration: none;
    background: #f7f7f5;
    border-top: 1px solid #e5e5e1;
  }

  .contact-shell-map-link:hover {
    background: #f0f0ec;
    text-decoration: none;
  }

  @media (max-width: 1024px) {
    .contact-shell {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .contact-shell-map {
      min-height: 24rem;
    }
  }

  @media (max-width: 640px) {
    .contact-shell-info {
      padding: 1.4rem 1.25rem 1.5rem;
    }

    .contact-shell-item {
      gap: 0.75rem;
    }
  }
</style>
