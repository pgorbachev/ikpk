---
import type { Article } from '../lib/data';
import { excerpt, formatDate } from '../lib/data';
import MediaCard from './ui/MediaCard.astro';

interface Props {
  article: Article;
}

const { article } = Astro.props as Props;
---

<MediaCard
  href={`/statyi/${article.slug}`}
  title={article.title}
  image={article.image ?? undefined}
  imageAlt={article.title}
  className="article-card"
  titleClassName="article-card-title"
>
  {article.published_at && (
    <time class="article-card-date text-muted text-small" datetime={article.published_at}>
      {formatDate(article.published_at)}
    </time>
  )}
  {article.body_text && (
    <p class="article-card-excerpt">{excerpt(article.body_text, 150)}</p>
  )}
</MediaCard>

<style>
  :global(.article-card .article-card-title) {
    margin-bottom: 0.25rem;
  }

  .article-card-date {
    display: block;
    margin-bottom: 0.5rem;
  }

  .article-card-excerpt {
    font-size: var(--font-s);
    color: var(--color-gray-600);
    line-height: 1.5;
  }
</style>
