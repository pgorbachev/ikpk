---
interface Props {
  href: string;
  name: string;
  photo?: string;
  excerpt?: string;
}

const { href, name, photo = '', excerpt = '' } = Astro.props as Props;
---

<a href={href} class="teacher-card" data-testid="institute-teacher-card">
  {photo && (
    <div class="teacher-card-photo">
      <img src={photo} alt={name} loading="lazy" width="280" height="240" />
    </div>
  )}
  <div class="teacher-card-body">
    <h3 class="teacher-card-title">{name}</h3>
    {excerpt && <p class="teacher-card-excerpt">{excerpt}</p>}
  </div>
</a>

<style>
  .teacher-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid #d9d9d4;
    background: #fafaf8;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.16);
    color: inherit;
    text-decoration: none;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }

  .teacher-card:hover {
    text-decoration: none;
    transform: translateY(-1px);
    border-color: #cdcdc7;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
  }

  .teacher-card-photo {
    aspect-ratio: 1.14;
    overflow: hidden;
    background: #ecece8;
  }

  .teacher-card-photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .teacher-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem 1rem 1.15rem;
  }

  .teacher-card-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
    color: var(--color-dark-700);
  }

  .teacher-card-excerpt {
    margin: 0.6rem 0 0;
    font-size: var(--font-s);
    line-height: 1.55;
    color: var(--color-gray-600);
  }

  :root[data-theme='dark'] .teacher-card {
    border-color: #434a43;
    background: #232723;
  }

  :root[data-theme='dark'] .teacher-card-photo {
    background: #2c312c;
  }
</style>
