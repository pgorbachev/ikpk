---
interface Props {
  href: string;
  title: string;
  description?: string;
  image?: string;
  fallbackLogo?: string;
}

const { href, title, description = '', image = '', fallbackLogo = '' } = Astro.props as Props;
---

<a href={href} class="program-card" data-testid="institute-program-card" aria-label={description ? `${title}. ${description}` : title}>
  <div class="program-card-media">
    {image ? (
      <img src={image} alt={title} loading="lazy" width="320" height="220" />
    ) : (
      <div class="program-card-fallback">
        {fallbackLogo ? (
          <img
            class="program-card-fallback-logo"
            src={fallbackLogo}
            alt=""
            loading="lazy"
            width="180"
            height="96"
          />
        ) : (
          <span class="program-card-fallback-title">{title}</span>
        )}
        <span class="program-card-label">Программа обучения</span>
      </div>
    )}
  </div>
  <div class="program-card-body">
    <h3 class="program-card-title">{title}</h3>
  </div>
</a>

<style>
  .program-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid #d9d9d4;
    background: #fafaf8;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.16);
    color: inherit;
    text-decoration: none;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }

  .program-card:hover {
    text-decoration: none;
    transform: translateY(-1px);
    border-color: #cdcdc7;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
  }

  .program-card-media {
    min-height: 176px;
    background: #efefeb;
  }

  .program-card-media img {
    display: block;
    width: 100%;
    height: 176px;
    object-fit: cover;
  }

  .program-card-fallback {
    min-height: 176px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0) 36%),
      linear-gradient(135deg, #f4f4f1 0%, #e4e5df 100%);
  }

  .program-card-fallback-logo {
    max-width: min(76%, 180px);
    width: auto;
    height: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
    opacity: 0.88;
  }

  .program-card-label {
    font-size: var(--font-xs);
    color: var(--color-gray-500);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .program-card-fallback-title {
    font-size: var(--font-l);
    line-height: 1.35;
    font-weight: 600;
    color: var(--color-dark-700);
  }

  .program-card-body {
    padding: 1rem 1rem 1.15rem;
  }

  .program-card-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
    color: var(--color-dark-700);
  }

  :root[data-theme='dark'] .program-card {
    border-color: #434a43;
    background: #232723;
  }

  :root[data-theme='dark'] .program-card-media {
    background: #2d322d;
  }

  :root[data-theme='dark'] .program-card-fallback {
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0) 32%),
      linear-gradient(135deg, #2c312c 0%, #1f241f 100%);
  }

  :root[data-theme='dark'] .program-card-fallback-logo {
    opacity: 0.78;
    filter: brightness(1.05) contrast(0.92);
  }
</style>
