---
// Layout-вариант с верхней навигацией (редизайн B). Тот же <head> и аналитика,
// что у SidebarLayout (через общие компоненты) — варианты не расходятся по SEO.
// Сайдбара нет: полную перелинковку держит футер.
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
  preloadHero?: boolean;
}

import HeadMeta from '../components/HeadMeta.astro';
import TopNav from '../components/topnav/TopNav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const {
  title,
  description = 'Институт клинической прикладной кинезиологии — ведущий центр постдипломного образования в области холистической медицины.',
  ogImage,
  noindex = false,
  schema,
  preloadHero = false,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <HeadMeta
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      schema={schema}
      preloadHero={preloadHero}
    />
  </head>
  <body class="layout-topnav">
    <TopNav />
    <main data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
