---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
  preloadHero?: boolean;
  newsletterVariant?: 'band' | 'card' | 'none';
  /** Лёгкий режим без сайдбара — для 404 (цель <20KB, план 004 Этап 3) */
  noSidebar?: boolean;
}

import HeadMeta from '../components/HeadMeta.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const {
  title,
  description = 'Институт клинической прикладной кинезиологии — ведущий центр постдипломного образования в области холистической медицины.',
  ogImage,
  noindex = false,
  schema,
  preloadHero = false,
  newsletterVariant = 'band',
  noSidebar = false,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <HeadMeta
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      schema={schema}
      preloadHero={preloadHero}
    />
  </head>
  <body>
    <Header noMenuToggle={noSidebar} />
    {!noSidebar && <Sidebar />}
    {/* data-pagefind-body: индексируется только контент — шапка/сайдбар/футер
        с одинаковыми ссылками на всех 256 страницах размывали релевантность.
        noindex-страницы (404) из внутреннего поиска исключаются. */}
    <main data-pagefind-body={noindex ? undefined : true} data-pagefind-ignore={noindex ? true : undefined}>
      <slot />
    </main>

    {newsletterVariant !== 'none' && <NewsletterSignup variant={newsletterVariant} />}

    <Footer />

    <Analytics />
  </body>
</html>
