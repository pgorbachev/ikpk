  </head>
  <body>
    <Header />
    <Sidebar />
    <main>
      <slot />
    </main>

    <!-- Newsletter subscription -->
    <section class="newsletter">
      <div class="container newsletter-inner">
        <h2 class="newsletter-title">Подпишитесь на наши новости</h2>
        <p class="newsletter-subtitle">Чтобы не пропускать наши активности и акции</p>
        <form class="newsletter-form" action="#" method="post">
          <input
            type="email"
            name="email"
            placeholder="Ваш email"
            required
            class="newsletter-input"
          />
          <button type="submit" class="btn btn-accent newsletter-btn">Подписаться</button>
        </form>
      </div>
    </section>

    <Footer />
  </body>
</html>
