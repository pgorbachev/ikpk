---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
  preloadHero?: boolean;
  newsletterVariant?: 'band' | 'card' | 'none';
}

import HeadMeta from '../components/HeadMeta.astro';
import MotionScript from '../components/MotionScript.astro';
import TopNav from '../components/topnav/TopNav.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const {
  title,
  description = 'Институт клинической прикладной кинезиологии — ведущий центр постдипломного образования в области холистической медицины.',
  ogImage,
  noindex = false,
  schema,
  preloadHero = false,
  newsletterVariant = 'band',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <HeadMeta
      title={title}
      description={description}
      ogImage={ogImage}
      noindex={noindex}
      schema={schema}
      preloadHero={preloadHero}
    />
    <MotionScript />
  </head>
  <body class="layout-topnav">
    <TopNav />
    {/* data-pagefind-body: индексируется только контент — шапка/футер с
        одинаковыми ссылками на всех страницах размывали релевантность.
        noindex-страницы (404) из внутреннего поиска исключаются. */}
    <main data-pagefind-body={noindex ? undefined : true} data-pagefind-ignore={noindex ? true : undefined}>
      <slot />
    </main>

    {newsletterVariant !== 'none' && <NewsletterSignup variant={newsletterVariant} />}

    <Footer />

    <Analytics />
  </body>
</html>
