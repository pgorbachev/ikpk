---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
  preloadHero?: boolean;
  newsletterVariant?: 'band' | 'card' | 'none';
}

import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import '../styles/global.css';

const {
  title,
  description = 'Институт клинической прикладной кинезиологии — ведущий центр постдипломного образования в области холистической медицины.',
  ogImage,
  noindex = false,
  schema,
  preloadHero = false,
  newsletterVariant = 'band',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'ИКПК';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:image" content={ogImage || new URL('/favicon.svg', Astro.site).href} />

    <!-- Self-hosted Inter font -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-cyrillic.woff2" as="font" type="font/woff2" crossorigin />

    {preloadHero && <link rel="preload" href="/hero-main.svg" as="image" fetchpriority="high" />}

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

  </head>
  <body>
    <Header />
    <Sidebar />
    <main>
      <slot />
    </main>

    {newsletterVariant !== 'none' && <NewsletterSignup variant={newsletterVariant} />}

    <Footer />

    <!-- Analytics: sync stubs queue pageview immediately, heavy scripts load after idle -->
    <script is:inline>
      // Yandex.Metrika — queue pageview synchronously so it's never lost
      window.ym = window.ym || function (...args) {
        (window.ym.a = window.ym.a || []).push(args);
      };
      window.ym.l = +new Date();
      ym(39506315, 'init', { clickmap: true, trackLinks: true, accurateTrackBounce: true, webvisor: true });

      // Mail.ru — queue pageview synchronously
      const _tmr = window._tmr || (window._tmr = []);
      _tmr.push({ id: '3752684', type: 'pageView', start: new Date().getTime() });

      // Defer heavy script downloads
      function _loadAnalyticsScripts() {
        const d = document;
        // Yandex tag.js
        (function () {
          for (let j = 0; j < d.scripts.length; j += 1) {
            if (d.scripts[j].src === 'https://mc.yandex.ru/metrika/tag.js') return;
          }
          const k = d.createElement('script');
          k.async = true;
          k.src = 'https://mc.yandex.ru/metrika/tag.js';
          d.head.appendChild(k);
        })();
        // Mail.ru code.js
        if (!d.getElementById('tmr-code')) {
          const ts = d.createElement('script');
          ts.async = true;
          ts.id = 'tmr-code';
          ts.src = 'https://top-fwz1.mail.ru/js/code.js';
          d.head.appendChild(ts);
        }
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(_loadAnalyticsScripts, { timeout: 3000 });
      } else {
        setTimeout(_loadAnalyticsScripts, 2000);
      }
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/39506315" style="position:absolute;left:-9999px;" alt="" /></div></noscript>
    <noscript><div><img src="https://top-fwz1.mail.ru/counter?id=3752684;js=na" style="position:absolute;left:-9999px;" alt="" /></div></noscript>
  </body>
</html>
