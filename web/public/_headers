# NOTE: These headers use Netlify/Cloudflare Pages format.
# GitHub Pages ignores this file entirely — it has no custom header support.
# Kept for reference / future migration to Netlify or Cloudflare Pages.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.*
  Cache-Control: public, max-age=86400

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/sitemap*.xml
  Cache-Control: public, max-age=3600
