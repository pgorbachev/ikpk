{
  "kind": "collectionType",
  "collectionName": "seminars",
  "info": {
    "singularName": "seminar",
    "pluralName": "seminars",
    "displayName": "Seminar",
    "description": "Educational seminar or course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "full_text": {
      "type": "richtext"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "price": {
      "type": "decimal"
    },
    "duration": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "planned",
        "not_planned"
      ],
      "default": "planned"
    },
    "legacy_id": {
      "type": "string",
      "unique": true
    },
    "course_group": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course-group.course-group",
      "inversedBy": "seminars"
    },
    "teachers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::teacher.teacher",
      "inversedBy": "seminars"
    },
    "schedule_entries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::schedule-entry.schedule-entry",
      "mappedBy": "seminar"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
